<#
.SYNOPSIS
    Generates the complete HTML report from all phase data.

.DESCRIPTION
    Combines data from all assessment phases into a single formatted HTML report.
    Loads CSS styles from Templates/ReportStyles.css.

.PARAMETER OutputPath
    Directory where the report will be saved

.PARAMETER SkipPhase1
    Skip Phase 1 content in report

.PARAMETER SkipPhase2
    Skip Phase 2 content in report

.PARAMETER SkipPhase3
    Skip Phase 3 content in report

.PARAMETER SkipPhase4
    Skip Phase 4 content in report

.PARAMETER SkipPhase5
    Skip Phase 5 content in report

.PARAMETER SkipPhase6
    Skip Phase 6 content in report
#>
function New-M365AssessmentReport {
    param(
        [Parameter(Mandatory)]
        [string]$OutputPath,
        [switch]$SkipPhase1,
        [switch]$SkipPhase2,
        [switch]$SkipPhase3,
        [switch]$SkipPhase4,
        [switch]$SkipPhase5,
        [switch]$SkipPhase6
    )
    
    Write-AssessmentLog "Generating HTML report..." -Level Info
    # Ensure helper functions exist in this scope (fallbacks) in case module import didn't expose them
    if (-not (Get-Command New-HtmlTable -ErrorAction SilentlyContinue)) {
        function New-HtmlTable {
            param($Data, $Properties, $Headers)
            if (-not $Data -or $Data.Count -eq 0) { return "" }
            $html = "<div class='table-container'><table><thead><tr>"
            foreach ($h in $Headers) { $html += "<th>$h</th>" }
            $html += "</tr></thead><tbody>"
            foreach ($row in $Data) {
                $html += "<tr>"
                foreach ($p in $Properties) {
                    $val = ''
                    try { $val = $row.$p } catch { $val = '' }
                    if ($null -eq $val) { $val = '' }
                    $html += "<td>$val</td>"
                }
                $html += "</tr>"
            }
            $html += "</tbody></table></div>"
            return $html
        }
    }
    if (-not (Get-Command New-HtmlStatCard -ErrorAction SilentlyContinue)) {
        function New-HtmlStatCard { param([string]$Number, [string]$Label) return "<div class='stat-card'><div class='stat-number'>$Number</div><div class='stat-label'>$Label</div></div>" }
    }
    if (-not (Get-Command New-HtmlAlert -ErrorAction SilentlyContinue)) {
        function New-HtmlAlert { param([string]$Message, [string]$Type = 'info') $class = 'alert-info'; switch ($Type) { 'success' { $class = 'alert-success' }'warning' { $class = 'alert-warning' }'critical' { $class = 'alert-critical' } }; return "<div class='alert $class'>$Message</div>" }
    }
    if (-not (Get-Command Format-DateColumn -ErrorAction SilentlyContinue)) {
        function Format-DateColumn { param($Date) if ($Date) { return (Get-Date $Date).ToString('dd-MM-yyyy') } else { return 'N/A' } }
    }
    if (-not (Get-Command New-HtmlStatsGrid -ErrorAction SilentlyContinue)) {
        function New-HtmlStatsGrid { param([array]$Cards) $html = "<div class='stats-grid'>"; foreach ($c in $Cards) { $html += New-HtmlStatCard -Number $c.Number -Label $c.Label }; $html += "</div>"; return $html }
    }

    # SKU friendly name mapping (display names for common Microsoft SKUs)
    $script:SkuFriendlyMap = @{
        'AAD_PREMIUM_P2'         = 'Azure AD Premium P2'
        'ENTERPRISEPACK'         = 'Microsoft 365 E3'
        'M365_BUSINESS_PREMIUM'  = 'Microsoft 365 Business Premium'
        'O365_BUSINESS_PREMIUM'  = 'Microsoft 365 Business Premium'
        'M365_BUSINESS_STANDARD' = 'Microsoft 365 Business Standard'
        'O365_BUSINESS_STANDARD' = 'Microsoft 365 Business Standard'
        'EMS_E5'                 = 'Enterprise Mobility + Security E5'
        'EMS_E3'                 = 'Enterprise Mobility + Security E3'
        'POWER_BI_PRO'           = 'Power BI Pro'
        'FLOW_FREE'              = 'Power Automate Free'
        'POWER_BI_STANDARD'      = 'Power BI (Standard)'
        'WINDOWS_STORE'          = 'Windows Store'
        'AAD_PREMIUM'            = 'Azure AD Premium'
        'SP_T_STORAGE'           = 'SharePoint Extra Storage'
    }

    function Get-SkuDisplayName {
        param([string]$Sku)
        if (-not $Sku) { return 'Onbekende Licentie' }

        # Case-insensitive lookup into the friendly map
        $foundKey = $script:SkuFriendlyMap.Keys | Where-Object { $_.ToString().ToUpperInvariant() -eq $Sku.ToString().ToUpperInvariant() }
        if ($foundKey) { return $script:SkuFriendlyMap[$foundKey[0]] }

        # Best-effort fallback: replace underscores with spaces and convert to Title Case
        # Clean up some common prefixes
        $name = $Sku -replace 'MICROSOFT_', '' -replace 'STANDARD_', '' -replace 'PREMIUM_', ''
        
        try {
            $text = ($name -replace '_', ' ' -replace '\s+', ' ').ToLowerInvariant()
            $ti = (Get-Culture).TextInfo
            $result = $ti.ToTitleCase($text)
            if ([string]::IsNullOrWhiteSpace($result)) { return $Sku }
            return $result
        }
        catch {
            return $Sku  # Fallback to original SKU on error
        }
    }

    function SafeCount {
        param($obj)
        if ($null -eq $obj) { return 0 }
        try {
            return @($obj).Count
        }
        catch {
            return 0
        }
    }
    
    # Load CSS from external file
    $cssPath = Join-Path $PSScriptRoot "..\Templates\ReportStyles.css"
    if (Test-Path $cssPath) {
        $cssContent = Get-Content -Path $cssPath -Raw
    }
    else {
        Write-AssessmentLog "⚠️ CSS file not found at $cssPath, using minimal styles" -Level Warning
        $cssContent = "body { font-family: Arial, sans-serif; padding: 20px; }"
    }
    
    # Use a fixed template logo placed above the report title (Denjoy-tp1.png)
    # We prefer a simple file reference so the image is served from Templates when viewing locally.
    $preferredLogo = Join-Path $PSScriptRoot "..\Templates\BOLLETJE QUBE transparant.pngg"
    if (Test-Path $preferredLogo) {
        $logoSrc = "../Templates/BOLLETJE QUBE transparant.png"
    }
    else {
        # Fallback to an existing template logo if Denjoy-tp1.png is not present
        $logoSrc = "../Templates/BOLLETJE QUBE transparant.png"
    }
    
    $tenantName = $global:TenantInfo.DisplayName
    $reportDate = $global:AssessmentStartTime.ToString('dd-MM-yyyy HH:mm')
    
    $html = @"
<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>M365 Baseline Assessment - $tenantName</title>
    <!-- Google Fonts: Inter & Outfit -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
$cssContent
    </style>
</head>
<body>
    <a id="top"></a>
    
    <!-- Fixed Professional Header (menu only) -->
    <header class="header">
        <div class="header-inner">
            <nav class="header-nav">
                <a href="#phase1">Gebruikers</a>
                <a href="#phase2">Samenwerking</a>
                <a href="#phase3">Compliance</a>
                <a href="#phase4">Beveiliging</a>
                <a href="#phase5">Intune</a>
                <a href="#phase6">Azure</a>
            </nav>
        </div>
    </header>

    <!-- Main Container -->
    <div class="container">
        
        <!-- Report Intro / Meta with logo in a narrow right-aligned block next to the title -->
            <div class="content-block intro-header" style="margin-bottom: 18px; padding: 12px 28px;">
                <div style="display:flex; align-items:center; gap:16px; justify-content:space-between; width:100%;">
                    <div class="intro-meta" style="text-align:left;">
                        <h1 class="report-title" style="font-family: 'Outfit', sans-serif; font-size: 28px; color: #2E2E2E; margin: 0;">
                            <span class="title-main">M365 Baseline Assessment <span class="sep" style="color:#F7941D">›</span></span>
                            <span class="tenant-name">$tenantName</span>
                        </h1>
                        <p style="font-size: 14px; color: #6E6E6E; margin-top:6px;">
                            Gegenereerd op: <strong>$reportDate</strong> | Door: <strong>Denjoy - IT</strong>
                        </p>
                    </div>
                    <div class="intro-logo" style="flex:0 0 120px; display:flex; justify-content:center; align-items:center;">
                        <div style="background:#fff; padding:6px 8px; border-radius:8px; box-shadow:0 2px 6px rgba(0,0,0,0.04);">
                            <img src="$logoSrc" alt="Denjoy Logo">
                        </div>
                    </div>
                </div>
            </div>

"@

    # PHASE 1 CONTENT
    if (-not $SkipPhase1) {
        $html += @"
        <div id="phase1" class="phase-content">
            <h1>👥 Gebruikers</h1>
            <div class="phase-body">
            <div class="section">
                <h2 class="section-title">👥 Gebruikers Overzicht</h2>
"@
        
        $phase1Cards = @(
            @{Number = $global:Phase1Data.TotalUsers; Label = 'Totaal Gebruikers' },
            @{Number = $global:Phase1Data.EnabledUsers; Label = 'Actieve Gebruikers' },
            @{Number = $global:Phase1Data.DisabledUsers; Label = 'Uitgeschakelde Gebruikers' },
            @{Number = $(SafeCount $global:Phase1Data.GuestUsers); Label = 'Guest Gebruikers' }
        )
        $html += New-HtmlStatsGrid -Cards $phase1Cards
        
        # Prepare Guest Users Table (defer output so it can be shown after Global Administrators)
        $deferredGuestTable = ""
        if ($global:Phase1Data.GuestUsers -and (SafeCount $global:Phase1Data.GuestUsers) -gt 0) {
            $guestData = $global:Phase1Data.GuestUsers | Select-Object UserPrincipalName, DisplayName, AccountEnabled
            $guestTable = New-HtmlTable -Data $guestData -Properties @('UserPrincipalName', 'DisplayName', 'AccountEnabled') -Headers @('Guest Email', 'Display Name', 'Enabled')
            if ($guestTable) {
                $deferredGuestTable = "<h3>👥 Guest Users Detail ($(SafeCount $global:Phase1Data.GuestUsers))</h3>" + $guestTable
            }
        }
        
        # Global Admins
            if ($global:Phase1Data.GlobalAdmins -and (SafeCount $global:Phase1Data.GlobalAdmins) -gt 0) {
            $globalAdminData = $global:Phase1Data.GlobalAdmins | ForEach-Object {
                [PSCustomObject]@{
                    UserPrincipalName = $_.UserPrincipalName
                    DisplayName       = $_.DisplayName
                    Status            = if ($_.AccountEnabled) { "✓ Enabled" } else { "✗ Disabled" }
                }
            }
            $globalAdminTable = New-HtmlTable -Data $globalAdminData -Properties @('UserPrincipalName', 'DisplayName', 'Status') -Headers @('User Principal Name', 'Display Name', 'Status')
            if ($globalAdminTable) {
                $html += "<h3>👤 Global Administrators ($(SafeCount $global:Phase1Data.GlobalAdmins))</h3>"
                $html += $globalAdminTable
                    # Short recommendation for Global Admins
                    $html += '<div class="alert alert-warning"><b>Aanbeveling:</b> Beperk het aantal Global Admins, gebruik rolgerichte admin-accounts en beheer verhoogde rechten via PIM.</div>'
            }

        # If we prepared a deferred guest table, output it here (directly under Global Administrators)
        if ($deferredGuestTable -and $deferredGuestTable -ne "") {
            $html += "<div class='section'>"
            $html += $deferredGuestTable
            $html += '<div class="alert alert-info"><b>Aanbeveling:</b> Review gastaccounts regelmatig via Access Reviews en beperk rechten voor guests.</div>'
            $html += "</div>"
        }
        }

        # Subsection: Active users list (limited to first 200)
        $activeUsers = @()
        if ($global:Phase1Data.AllUsers) {
            $activeUsers = $global:Phase1Data.AllUsers | Where-Object { $_.AccountEnabled -eq $true } | Select-Object -First 200 | ForEach-Object {
                [PSCustomObject]@{
                    UserPrincipalName = $_.UserPrincipalName
                    DisplayName       = $_.DisplayName
                    Status            = if ($_.AccountEnabled) { "✓ Enabled" } else { "✗ Disabled" }
                }
            }
        }

        $activeUsersTable = New-HtmlTable -Data $activeUsers -Properties @('UserPrincipalName', 'DisplayName', 'Status', 'Licenses') -Headers @('User Principal Name', 'Display Name', 'Status', 'Licenties')
        if ($activeUsersTable) {
            $html += "<h3>👥 Actieve gebruikers ($($global:Phase1Data.EnabledUsers))</h3>"
            $html += $activeUsersTable
        }

        # Subsection: Disabled users list (uitgeschakelde gebruikers)
        $disabledUsers = @()
        # Prefer the RAW user list (includes unlicensed/disabled accounts). Fallback to filtered AllUsers if RAW not available.
        $sourceUsers = if ($global:Phase1Data.AllUsersRaw) { $global:Phase1Data.AllUsersRaw } elseif ($global:Phase1Data.AllUsers) { $global:Phase1Data.AllUsers } else { @() }
        if ($sourceUsers) {
            $disabledUsers = $sourceUsers | Where-Object { $_.AccountEnabled -eq $false } | ForEach-Object {
                [PSCustomObject]@{
                    UserPrincipalName = $_.UserPrincipalName
                    DisplayName       = $_.DisplayName
                    Status            = '✗ Uitgeschakeld'
                    LastSignIn        = Format-DateColumn $_.LastSignInDateTime
                }
            }
        }

        $disabledUsersTable = New-HtmlTable -Data $disabledUsers -Properties @('UserPrincipalName','DisplayName','Status','LastSignIn') -Headers @('User Principal Name','Display Name','Status','Laatste aanmelding')
        if ($disabledUsersTable) {
            $html += "<h3>🚫 Uitgeschakelde gebruikers ($(SafeCount $disabledUsers))</h3>"
            $html += $disabledUsersTable
        }
        
        
        $html += @"
        </div> <!-- End Overview Section -->

        <!-- MFA Section - Included in phase-content -->
        <div class="section">
            <h2 class="section-title">🔐 Multi-Factor Authentication (MFA)</h2>
            <div class="stats-grid">
                <div class="stat-card">
                    <div class="stat-number">$($global:Phase1Data.EnabledMemberUsers)</div>
                    <div class="stat-label">Totaal Member Users</div>
                </div>
                <div class="stat-card stat-card--warning">
                    <div class="stat-number">$(SafeCount $global:Phase1Data.UsersWithoutMFA)</div>
                    <div class="stat-label">Zonder MFA</div>
                </div>
                <div class="stat-card">
                    <div class="stat-number">$(if ($global:Phase1Data.EnabledMemberUsers -gt 0 -and -not $global:Phase1Data.MFACheckFailed) { [math]::Round((($global:Phase1Data.EnabledMemberUsers - (SafeCount $global:Phase1Data.UsersWithoutMFA)) / $global:Phase1Data.EnabledMemberUsers) * 100, 1) } else { '?' })%</div>
                    <div class="stat-label">MFA Coverage</div>
                </div>
            </div>
            
            <div class="alert alert-warning">
                <strong>ℹ️ Belangrijke Opmerking over MFA Data</strong><br>
                Dit rapport toont <strong>MFA REGISTRATIE</strong> (welke users hebben MFA methods geregistreerd zoals Authenticator app, phone, etc).<br>
                <br>
                <strong>Dit is NIET hetzelfde als "Per-user MFA Enforcement"!</strong><br>
                <ul style="margin: 10px 0 0 20px;">
                    <li><strong>Disabled:</strong> MFA niet afgedwongen (zelfs als methods geregistreerd zijn)</li>
                    <li><strong>Enabled:</strong> MFA afgedwongen, user moet registreren bij volgende login</li>
                    <li><strong>Enforced:</strong> MFA geregistreerd en actief afgedwongen</li>
                </ul>
                <br>
                <strong>➡️ Check per-user MFA enforcement status in:</strong><br>
                Azure AD Portal → Users → Per-user MFA (of gebruik Conditional Access policies)
            </div>
            
            <p style="color: #666; margin-bottom: 20px;">
                <strong>Scope:</strong> Actieve users (geen guest users)
            </p>
"@
        
        # Show warning if MFA check failed
        if ($global:Phase1Data.MFACheckFailed) {
            $html += @"
                <div class="alert alert-critical">
                    <strong>⚠️ MFA Check Gefaald</strong><br>
                    De MFA registratie status kon niet worden geverifieerd.
                    <ul style="margin: 10px 0 0 20px;">
                        <li>Insufficient permissions (UserAuthenticationMethod.Read.All vereist)</li>
                        <li>API limitatie of timeout</li>
                        <li>Users hebben geen authentication methods geconfigureerd</li>
                    </ul>
                    <strong><b>Aanbeveling:</b></strong> Verifieer MFA status handmatig in Azure AD Portal → Users → Per-user MFA
                </div>
"@
        }
        else {
            # Exclude Guest users from the "Users without MFA" list so Guests only appear
            # in the dedicated Guest Users section.
            $usersNoMfaList = if ($global:Phase1Data.UsersWithoutMFA) { $global:Phase1Data.UsersWithoutMFA | Where-Object { $_.UserType -ne 'Guest' } } else { @() }

            if ((SafeCount $usersNoMfaList) -gt 0) {
                # Users WITHOUT MFA registration - show table (excluding Guests)
                $usersNoMfaData = $usersNoMfaList | ForEach-Object {
                    [PSCustomObject]@{
                        UserPrincipalName = $_.UserPrincipalName
                        DisplayName       = $_.DisplayName
                        Status            = if ($_.AccountEnabled) { "✓ Actief" } else { "✗ Uitgeschakeld" }
                    }
                }
                $usersNoMfaTable = New-HtmlTable -Data $usersNoMfaData -Properties @('UserPrincipalName', 'DisplayName', 'Status') -Headers @('User Principal Name', 'Display Name', 'Account Status')
                if ($usersNoMfaTable) {
                    $html += "<h3>⚠️ Gebruikers zonder geregistreerde MFA ($(SafeCount $usersNoMfaList))</h3>"
                    $html += New-HtmlAlert -Type critical -Message "<strong>Actie vereist:</strong> Deze gebruikers hebben geen MFA methods geregistreerd (zoals Authenticator app, phone number, etc)."
                    $html += $usersNoMfaTable
                }
            }
            else {
                $html += '<div class="alert alert-success"><strong>✓ Good!</strong> Alle actieve member users hebben MFA methods geregistreerd.<br><small>Let op: Dit betekent NIET automatisch dat per-user MFA enforcement actief is!</small></div>'
            }
        }
        $html += "</div> <!-- End MFA Section -->"

        # CA <-> MFA Cross-check summary (if available)
        if ($global:Phase1Data.CA_MFA_CrossCheck -and (SafeCount $global:Phase1Data.CA_MFA_CrossCheck) -gt 0) {
            $caSummary = $global:Phase1Data.CA_MFA_CrossCheck
            $totalPolicies = $caSummary.Count
            # Sum of each policy's targeted user count (may double-count users appearing in multiple policies)
            $totalTargetedUsers = ($caSummary | Measure-Object -Property TargetedUsersCount -Sum).Sum

            # Compute unique targeted users across all policies to avoid double-counting
            # Be resilient: some policies may not include a full TargetedUsers array,
            # so fall back to TargetedUnregistered where available.
            $allTargets = @()
            foreach ($p in $caSummary) {
                $candidates = @()
                if ($p.TargetedUsers -and (SafeCount $p.TargetedUsers) -gt 0) {
                    $candidates = $p.TargetedUsers
                }
                elseif ($p.TargetedUnregistered -and (SafeCount $p.TargetedUnregistered) -gt 0) {
                    $candidates = $p.TargetedUnregistered
                }

                foreach ($u in $candidates) {
                    $id = $null
                    if ($u -is [string]) { $id = $u }
                    else {
                        if ($u.UserPrincipalName) { $id = $u.UserPrincipalName }
                        elseif ($u.Mail) { $id = $u.Mail }
                        elseif ($u.Upn) { $id = $u.Upn }
                    }
                    if ($id) { $allTargets += $id }
                }
            }
            $uniqueTargetedUsers = ($allTargets | Where-Object { $_ } | Sort-Object -Unique).Count

            $totalUnregistered = ($caSummary | Measure-Object -Property TargetedUnregisteredCount -Sum).Sum

            # Build safe HTML block using here-strings to avoid nested-quote issues
                        $caHtml = @'
<div class="section">
    <h2 class="section-title">🔁 Cross-check: Conditional Access ↔ MFA</h2>
    <p style="margin-top:8px; color:#555;">Deze cross-check vergelijkt Conditional Access-policies die MFA vereisen met per-user MFA-registratiegegevens om te identificeren welke gebruikers niet geregistreerd zijn voor MFA.</p>
</div>
'@

            # Stat cards
            $caStatCards = @(
                @{ Number = $uniqueTargetedUsers; Label = 'Users targeted by CA requiring MFA' },
                @{ Number = $totalUnregistered; Label = 'Targeted but unregistered' }
            )

            $html += $caHtml
            if ($caStatCards.Count -gt 0) { $html += New-HtmlStatsGrid -Cards $caStatCards }

            # Build a flattened mapping of all targeted users to their policies and MFA status
            $userMap = @{}
            foreach ($p in $caSummary) {
                $candidates = @()
                if ($p.TargetedUsers -and (SafeCount $p.TargetedUsers) -gt 0) { $candidates = $p.TargetedUsers }
                elseif ($p.TargetedUnregistered -and (SafeCount $p.TargetedUnregistered) -gt 0) { $candidates = $p.TargetedUnregistered }

                foreach ($u in $candidates) {
                    $upn = $null; $display = $null
                    if ($u -is [string]) { $upn = $u }
                    else {
                        if ($u.UserPrincipalName) { $upn = $u.UserPrincipalName }
                        elseif ($u.Mail) { $upn = $u.Mail }
                        if ($u.DisplayName -and -not ($u.DisplayName -is [bool])) { $display = $u.DisplayName }
                    }
                    if (-not $upn) { continue }

                    if (-not $userMap.ContainsKey($upn)) {
                        $isRegistered = 'Ja'
                        try {
                            if ($global:Phase1Data.UsersWithoutMFA) {
                                $match = $global:Phase1Data.UsersWithoutMFA | Where-Object { ($_ -is [string] -and $_ -eq $upn) -or ($_.UserPrincipalName -and $_.UserPrincipalName -eq $upn) }
                                if ($match) { $isRegistered = 'Nee' }
                            }
                        } catch { }

                        $userMap[$upn] = [PSCustomObject]@{
                            UserPrincipalName = $upn
                            DisplayName       = ($display -or $upn)
                            CAPolicies        = @($p.PolicyName)
                            MFARegistered     = $isRegistered
                            EnforcementStatus = 'Unknown'
                        }
                    }
                    else {
                        $userMap[$upn].CAPolicies += $p.PolicyName
                    }
                }
            }

            $tableRows = @()
            foreach ($entry in $userMap.GetEnumerator() | ForEach-Object { $_.Value }) {
                $tableRows += [PSCustomObject]@{
                    UserPrincipalName = $entry.UserPrincipalName
                    CA_Policies       = ($entry.CAPolicies -join '; ')
                    MFARegistered     = $entry.MFARegistered
                    EnforcementStatus = $entry.EnforcementStatus
                }
            }

            $mismatchCount = @($tableRows | Where-Object { $_.MFARegistered -eq 'Nee' }).Count
            if ($mismatchCount -gt 0) {
                $html += New-HtmlAlert -Type critical -Message ("<strong>⚠️ $mismatchCount gebruikers vallen binnen CA policies die MFA vereisen maar hebben geen geregistreerde MFA-methodes.</strong>")
            }

            if ($tableRows.Count -gt 0) {
                $html += "<h3 style='margin-top:12px;'>CA↔MFA Summary (per-user)</h3>"
                $html += New-HtmlTable -Data ($tableRows | Sort-Object UserPrincipalName) -Properties @('UserPrincipalName','CA_Policies','MFARegistered','EnforcementStatus') -Headers @('User','CA Policies','MFA Registered','Enforcement')
            }

            # Per-policy stat cards: show how many targeted users are unregistered per policy
            $policyCards = @()
            foreach ($p in $caSummary) {
                $unreg = 0
                $targeted = 0
                try { $unreg = [int]$p.TargetedUnregisteredCount } catch { $unreg = 0 }
                try { $targeted = [int]$p.TargetedUsersCount } catch { $targeted = 0 }

                $label = $p.PolicyName
                # Shorten very long policy names for the card label if necessary
                if ($label.Length -gt 60) { $label = $label.Substring(0,57) + '...' }

                # Show excluded count as Number and put policy name as label
                $policyCards += @{ Number = "$unreg / $targeted"; Label = $label }
            }
            if ($policyCards.Count -gt 0) {
                $html += "<h3 style='margin-top:12px;'>Per-policy uitsluitingen (niet geregistreerde MFA / Gebruikers)</h3>"
                $html += New-HtmlStatsGrid -Cards $policyCards
            }

            # (Overall summary cards removed by request) - only per-policy cards are shown above

            # Build a flattened list of unregistered targeted users across all policies
            $flatUnreg = @()
            foreach ($p in $caSummary) {
                if ($p.TargetedUnregistered) {
                    foreach ($u in $p.TargetedUnregistered) {
                        $upn = if ($u -is [string]) { $u } elseif ($u.UserPrincipalName) { $u.UserPrincipalName } elseif ($u.Mail) { $u.Mail } else { $null }
                        $display = if ($u.DisplayName) { $u.DisplayName } elseif ($u.DisplayName -eq $null -and $u.Mail) { $u.Mail } else { 'N/A' }
                        if ($upn) {
                            $flatUnreg += [PSCustomObject]@{
                                PolicyName = $p.PolicyName
                                UserPrincipalName = $upn
                                DisplayName = $display
                            }
                        }
                    }
                }
            }

            # Deduplicate by UserPrincipalName and aggregate policy names
            $uniqueUnreg = @()
            if ((SafeCount $flatUnreg) -gt 0) {
                $groups = $flatUnreg | Group-Object -Property UserPrincipalName
                foreach ($g in $groups) {
                    $entry = $g.Group | Select-Object -First 1
                    $policies = ($g.Group | ForEach-Object { $_.PolicyName }) -join '; '
                    $uniqueUnreg += [PSCustomObject]@{
                        UserPrincipalName = $entry.UserPrincipalName
                        DisplayName = $entry.DisplayName
                        CAPolicies = $policies
                    }
                }

                $sample = $uniqueUnreg | Select-Object -First 200
                $html += "<h3>⚠️ Gebruikers zonder geregistreerde MFA (uniek: $($uniqueUnreg.Count))</h3>"
                $html += New-HtmlTable -Data $sample -Properties @('UserPrincipalName','DisplayName','CAPolicies') -Headers @('User','Display Name','CA Policies')
            }
            else {
                $html += '<div class="alert alert-success">Geen gebruikers zonder geregistreerde MFA gevonden voor policies die MFA vereisen.</div>'
            }

            # (Removed) CA↔MFA inline recommendations — moved to Phase 1 recommendations
        }
        
        <!-- Guest Users Section removed (duplicate) -->
        
        $html += @"
        <div class="section">
            <h2 class="section-title">💳 Licentie Overzicht</h2>
            <p style='margin-top:6px; color:#555;'><b>Aanbeveling:</b> Gebruik group-based licensing en maak een maandelijkse review voor low-utilization licenties.</p>
"@
        # Create per-license stat cards (Consumed / Utilization)
        if ($global:Phase1Data.Licenses -and (SafeCount $global:Phase1Data.Licenses) -gt 0) {
            $licenseCards = @()
            foreach ($lic in $global:Phase1Data.Licenses) {
                $num = if ($null -ne $lic.Total) { $lic.Total } else { 0 }
                $displayName = Get-SkuDisplayName $lic.SkuPartNumber
                if (-not $displayName -or $displayName -eq '') { $displayName = $lic.SkuPartNumber }
                $label = "${displayName}<br><span style='font-size:0.8em; font-weight:normal; opacity:0.8;'>$($lic.Consumed) in gebruik</span>"
                $licenseCards += @{ Number = $num; Label = $label }
            }
            if ($licenseCards.Count -gt 0) { $html += New-HtmlStatsGrid -Cards $licenseCards }
            $html += "<br>"
        }
        if ($global:Phase1Data.Licenses -and (SafeCount $global:Phase1Data.Licenses) -gt 0) {
            foreach ($license in $global:Phase1Data.Licenses) {
                $displayHeader = Get-SkuDisplayName $($license.SkuPartNumber)
                if (-not $displayHeader -or $displayHeader -eq '') { $displayHeader = $license.SkuPartNumber }
                $html += @"
        <h3 style="margin-top: 25px; color: #333;">$displayHeader</h3>
        <div class="alert alert-info" style="margin-bottom: 15px; background: #eef7ff; border-left: 5px solid #0066b3; font-weight: 500;">
        <strong>Totaal:</strong> $($license.Total) &nbsp; | &nbsp; 
        <strong>Gebruikt:</strong> $($license.Consumed) &nbsp; | &nbsp; 
        <strong>Beschikbaar:</strong> $($license.Available) &nbsp; | &nbsp; 
        <strong>Benutting:</strong> $($license.Utilization)%
        </div>
"@
                if ($license.AssignedUsers -and $license.AssignedUsers.Count -gt 0) {
                    $html += @"
        <div class="table-container">
        <table>
        <thead>
        <tr>
        <th>User Principal Name</th>
        <th>Display Name</th>
        </tr>
        </thead>
        <tbody>
"@
                    foreach ($user in $license.AssignedUsers) {
                        $html += "<tr><td>$($user.UserPrincipalName)</td><td>$($user.DisplayName)</td></tr>"
                    }
                    $html += @"
        </tbody>
        </table></div><br>
"@
                }
                else {
                    $html += "<p style='color: #888; font-style: italic; margin-bottom: 20px;'>Geen gebruikers toegewezen aan deze licentie.</p>"
                }
            }
        }
        else {
            $html += "<p>Geen licentie informatie beschikbaar.</p>"
        }
        
        
        $html += "            </div>"  # Close license section
        
        # PHASE 1 RECOMMENDATIONS - At the end of the phase
        $html += @"
        <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
        <h2 class="section-title">💡 Aanbevelingen - Phase 1: Users, Licensing & Security Basics</h2>
        <p style="margin-bottom: 20px; color: #666;">Microsoft best practices voor gebruikersbeheer, licenties en basis security:</p>
"@
        
        # Build recommendations
        $phase1Recs = @()
        
        if ($global:Phase1Data.UsersWithoutMFA.Count -gt 0) {
            $phase1Recs += New-HtmlAlert -Type critical -Message "<strong>⚠️ MFA Enforcement (Critical):</strong> $($global:Phase1Data.UsersWithoutMFA.Count) gebruiker(s) hebben geen MFA geregistreerd. <br><strong>Microsoft Best Practice:</strong> Implementeer MFA voor alle gebruikers via Conditional Access policies. Gebruik passwordless authentication (Windows Hello, FIDO2, Authenticator app) waar mogelijk."
        }
        
        if ($global:Phase1Data.GlobalAdmins.Count -gt 5) {
            $phase1Recs += New-HtmlAlert -Type warning -Message "<strong>👤 Admin Accounts (Belangrijk):</strong> $($global:Phase1Data.GlobalAdmins.Count) Global Administrators gedetecteerd. <br><strong>Microsoft Best Practice:</strong> Beperk Global Admin accounts tot maximaal 2-5. Gebruik role-based access control (RBAC) met specifiekere admin rollen. Implementeer Privileged Identity Management (PIM) voor just-in-time admin toegang."
        }
        elseif ($global:Phase1Data.GlobalAdmins.Count -eq 0) {
            $phase1Recs += New-HtmlAlert -Type critical -Message "<strong>⚠️ Geen Global Admins (Critical):</strong> Geen Global Administrators gevonden. Dit kan een security risk zijn. <br><strong>Microsoft Best Practice:</strong> Zorg voor minimaal 2 emergency access (break-glass) accounts met Global Admin rechten."
        }
        
        if ($global:Phase1Data.GuestUsers.Count -gt 0) {
            $phase1Recs += New-HtmlAlert -Type info -Message "<strong>👥 Guest Users ($($global:Phase1Data.GuestUsers.Count)):</strong> <br><strong>Microsoft Best Practice:</strong> Implementeer een guest access policy: (1) Review guest users elke 3-6 maanden, (2) Gebruik access reviews voor automatische verificatie, (3) Beperk guest permissions via Azure AD External Identities settings, (4) Monitor guest activiteit via audit logs."
        }
        
        $lowUtilization = $global:Phase1Data.Licenses | Where-Object { $_.Utilization -lt 80 -and $_.Total -gt 5 }
        if ($lowUtilization) {
            $licenseDetails = ($lowUtilization | ForEach-Object { "$($_.Name) ($($_.Utilization) % )" }) -join ', '
            $phase1Recs += New-HtmlAlert -Type info -Message "<strong>💰 License Optimalisatie:</strong> Sommige licenties hebben lage utilization: $licenseDetails. <br><strong>Microsoft Best Practice:</strong> Review licentietoewijzingen maandelijks. Gebruik group-based licensing voor automatisch beheer. Implementeer een license reclamation proces voor inactive users."
        }
        
        # CA ↔ MFA: add recommendation based on cross-check results (severity per MS best practices)
        if ($global:Phase1Data.CA_MFA_CrossCheck -and (SafeCount $global:Phase1Data.CA_MFA_CrossCheck) -gt 0) {
            try {
                $totalUnregistered = ($global:Phase1Data.CA_MFA_CrossCheck | Measure-Object -Property TargetedUnregisteredCount -Sum).Sum
                $totalPolicies = ($global:Phase1Data.CA_MFA_CrossCheck).Count
            }
            catch {
                $totalUnregistered = 0
                $totalPolicies = 0
            }

            if ($totalUnregistered -gt 0) {
                $phase1Recs += New-HtmlAlert -Type critical -Message "<strong>⚠️ CA↔MFA Mismatch (Critical):</strong> $(uniqueUnreg.Count) gebruiker(s) vallen binnen Conditional Access policies die MFA vereisen maar hebben geen geregistreerde MFA-methodes. <br><strong>Microsoft Best Practice:</strong> Corrigeer deze gebruikers: forceer MFA via Conditional Access (GrantControls: Require multifactor authentication) in plaats van per-user uitzonderingen. Gebruik phishing-resistente methodes (FIDO2) voor kritische accounts en monitor Sign-in logs."
            }
            else {
                $phase1Recs += New-HtmlAlert -Type info -Message "<strong>✅ CA↔MFA Check:</strong> $totalPolicies Conditional Access policy(ies) vereisen MFA en er zijn geen geuikers zonder geregistreerde MFA gevonden. <br><strong>Microsoft Best Practice:</strong> Blijf monitoren en behoud least-privilege en phishing-resistente authenticatie voor admin accounts."
            }
        }

        # Always show general best practices even if no specific recommendations
        if ((SafeCount $phase1Recs) -eq 0) {
            $phase1Recs += New-HtmlAlert -Type success -Message "<strong>✅ Geen kritieke issues gevonden in Phase 1</strong>"
        }
        
        # Add general Microsoft best practices
        $html += @"
        <div style="margin-top: 15px;">
"@
        foreach ($rec in $phase1Recs) {
            $html += "                    $rec"
        }
        
        $html += @"
        </div>
                
        <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
        <h4 style="margin-top: 0;">📋 Algemene Best Practices - Phase 1</h4>
        <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
        <li><strong>Identity Protection:</strong> Schakel Azure AD Identity Protection in voor risk-based conditional access</li>
        <li><strong>Password Policy:</strong> Gebruik Azure AD Password Protection om zwakke wachtwoorden te blokkeren</li>
        <li><strong>Admin Accounts:</strong> Gebruik dedicated admin accounts (gescheiden van reguliere accounts)</li>
        <li><strong>Monitoring:</strong> Configureer alerts voor admin role changes en risky sign-ins</li>
        <li><strong>Lifecycle Management:</strong> Implementeer joiner/mover/leaver processen voor gebruikersbeheer</li>
        <li><strong>License Management:</strong> Gebruik automatische license assignment via groups waar mogelijk</li>
        </ul>
        </div>
        </div>
"@
        

        # SMTP AUTH moved to Phase 2 (mailbox-level checks belong with Exchange/Collaboration)
        
        $html += "        </div> <!-- End Phase Body -->`n        </div> <!-- End Phase 1 Content -->"
    }
    
    # PHASE 2 CONTENT - REFACTORED STRUCTURE
    if (-not $SkipPhase2) {
        $html += @"
        <div id="phase2" class="phase-content">
        <h1>📊 Samenwerking</h1>
        <div class="phase-body">
            
        <!-- Overview Stats -->
        <div class="section">
        <h2 class="section-title">📈 Overzicht</h2>
        <div class="stats-grid">
        <div class="stat-card">
        <div class="stat-number">$($global:Phase2Data.TotalTeams)</div>
        <div class="stat-label">Microsoft Teams</div>
        </div>
        <div class="stat-card">
        <div class="stat-number">$($global:Phase2Data.TotalGroups)</div>
        <div class="stat-label">M365 Groups</div>
        </div>
        <div class="stat-card">
        <div class="stat-number">$($global:Phase2Data.DistributionGroups.Count)</div>
        <div class="stat-label">Distribution Lists</div>
        </div>
        <div class="stat-card">
        <div class="stat-number">$($global:Phase2Data.SecurityGroups.Count)</div>
        <div class="stat-label">Security Groups</div>
        </div>
        </div>
        <!-- SMTP AUTH summary (per-mailbox) -->
        <div class="section">
        <h3 class="section-title">✉️ SMTP AUTH (mailbox-level)</h3>
        <div style="color:#555;margin-top:6px;">
"@
        $smtp = $global:Phase2Data.SmtpAuth
        if ($smtp) {
            # Compute an accurate mailbox count: prefer explicit Mailboxes/Sample arrays, fallback to Count property or array length
            $smtpCount = 0
            try {
                if ($smtp -is [System.Collections.Hashtable] -and $smtp.ContainsKey('Mailboxes') -and $smtp.Mailboxes) { $smtpCount = @($smtp.Mailboxes).Count }
                elseif ($smtp -is [System.Collections.Hashtable] -and $smtp.ContainsKey('Sample') -and $smtp.Sample) { $smtpCount = @($smtp.Sample).Count }
                elseif ($smtp -is [System.Collections.Hashtable] -and $smtp.ContainsKey('Count')) { $smtpCount = [int]$smtp.Count }
                else { $smtpCount = @($smtp).Count }
            } catch { $smtpCount = 0 }

            $html += "<p>Mailboxes with SMTP AUTH enabled: $($smtpCount)</p>"
            try {
                # Prefer showing the sample if available, else show first 50 mailboxes
                $tableData = @()
                if ($smtp.Sample -and ($smtp.Sample | Measure-Object).Count -gt 0) {
                    $tableData = $smtp.Sample | ForEach-Object {
                        [PSCustomObject]@{
                            UserPrincipalName = $_.UserPrincipalName
                            DisplayName = ($_.DisplayName -or '')
                            SMTPAuthEnabled = ($_.SmtpAuthEnabled -eq $true)
                        }
                    }
                }
                elseif ($smtp.Mailboxes -and ($smtp.Mailboxes | Measure-Object).Count -gt 0) {
                    $tableData = ($smtp.Mailboxes | Select-Object -First 50) | ForEach-Object {
                        [PSCustomObject]@{
                            UserPrincipalName = $_.UserPrincipalName
                            DisplayName = ($_.DisplayName -or '')
                            SMTPAuthEnabled = ($_.SmtpAuthEnabled -eq $true)
                        }
                    }
                }

                if ($tableData -and $tableData.Count -gt 0) {
                    $html += New-HtmlTable -Data $tableData -Properties @('UserPrincipalName','DisplayName','SMTPAuthEnabled') -Headers @('UPN','Display Name','SMTP Auth Enabled')
                }
            } catch {
                # If table rendering fails, show minimal note
                $html += "<p><em>Unable to render SMTP AUTH table: $($_.Exception.Message)</em></p>"
            }
        } else {
            if ($smtp -and $smtp.Note) { $html += "<p>Note: $($smtp.Note)</p>" }
        }
        $html += @"
        </div>
        </div>
        </div>
            
        <!-- M365 Groups & Teams Section -->
        <div class="section">
        <h2 class="section-title">🎯 Microsoft 365 Groups & Teams</h2>
        <p style="color: #666; margin-bottom: 20px;">
        Microsoft 365 Groups zijn moderne collaboration groepen met geïntegreerde mailbox, SharePoint site, en optioneel een Microsoft Team.
        </p>
"@
        # Modern Auth / Legacy Auth summary (Exchange)
        $modern = $global:Phase2Data.ExchangeModernAuth
        if ($modern) {
            try {
                $legacyCount = 0
                try { $legacyCount = @($modern.Mailboxes | Where-Object { $_.LegacyAuthAllowed -eq $true }).Count } catch { $legacyCount = 0 }

                $tenantModern = if ($modern.TenantModernAuthEnabled -eq $true) { 'Ja' } elseif ($modern.TenantModernAuthEnabled -eq $false) { 'Nee' } else { 'Onbekend' }

                $html += "<div class='section'><h3 class='section-title'>🔐 Exchange Modern Auth / Legacy Auth</h3><div style='color:#555;margin-top:6px;'>"
                $html += "<p>Tenant Modern Authentication enabled: <strong>$tenantModern</strong></p>"
                $html += "<p>Mailboxes allowing legacy auth: <strong>$legacyCount</strong></p>"

                # Prepare table: prefer SampleLegacy, else Mailboxes (first 50)
                $tableData = @()
                if ($modern.SampleLegacy -and ($modern.SampleLegacy | Measure-Object).Count -gt 0) {
                    $tableData = $modern.SampleLegacy | ForEach-Object {
                        [PSCustomObject]@{
                            UserPrincipalName = $_.UserPrincipalName
                            DisplayName = ($_.DisplayName -or $_.UserPrincipalName)
                            SmtpClientAuthDisabled = if ($null -ne $_.SmtpClientAuthDisabled) { $_.SmtpClientAuthDisabled } else { 'N/A' }
                            LegacyAuthAllowed = if ($_.LegacyAuthAllowed) { 'Ja' } else { 'Nee' }
                        }
                    }
                }
                elseif ($modern.Mailboxes -and ($modern.Mailboxes | Measure-Object).Count -gt 0) {
                    $tableData = ($modern.Mailboxes | Select-Object -First 50) | ForEach-Object {
                        [PSCustomObject]@{
                            UserPrincipalName = $_.UserPrincipalName
                            DisplayName = ($_.DisplayName -or $_.UserPrincipalName)
                            SmtpClientAuthDisabled = if ($null -ne $_.SmtpClientAuthDisabled) { $_.SmtpClientAuthDisabled } else { 'N/A' }
                            LegacyAuthAllowed = if ($_.LegacyAuthAllowed) { 'Ja' } else { 'Nee' }
                        }
                    }
                }

                if ($tableData -and $tableData.Count -gt 0) {
                    $html += New-HtmlTable -Data $tableData -Properties @('UserPrincipalName','DisplayName','SmtpClientAuthDisabled','LegacyAuthAllowed') -Headers @('UPN','Display Name','SmtpClientAuthDisabled','Legacy Allowed')
                }
                else {
                    if ($modern.Note) { $html += "<p><em>Note: $($modern.Note)</em></p>" }
                }

                $html += "</div></div>"
            }
            catch {
                $html += "<div class='section'><p><em>Could not render Exchange Modern Auth section: $($_.Exception.Message)</em></p></div>"
            }
        }
        
        # Microsoft Teams Details
        if ($global:Phase2Data.Teams -and $global:Phase2Data.Teams.Count -gt 0) {
            $html += "<h3>🎯 Microsoft Teams ($($global:Phase2Data.TotalTeams))</h3>"
            $teamsData = $global:Phase2Data.Teams | ForEach-Object {
                [PSCustomObject]@{
                    Mail        = $_.Mail
                    DisplayName = $_.DisplayName
                    MemberCount = $_.MemberCount
                    Created     = Format-DateColumn $_.CreatedDateTime
                }
            }
            $html += New-HtmlTable -Data $teamsData -Properties @('Mail', 'DisplayName', 'MemberCount', 'Created') -Headers @('Email', 'Team Name', 'Members', 'Created')
            # Meeting policies summary (from Phase2)
            if ($global:Phase2Data.MeetingPolicies) {
                try {
                    $mpCount = if ($null -ne $global:Phase2Data.MeetingPolicies.Count) { $global:Phase2Data.MeetingPolicies.Count } else { 0 }
                    $html += "<h4 style='margin-top:10px;'>📋 Teams Meeting Policies ($mpCount)</h4>"
                    if ($mpCount -gt 0) {
                        $mpRows = $global:Phase2Data.MeetingPolicies | ForEach-Object {
                            # Robust name selection (avoid using -or which returns boolean)
                            $name = 'N/A'
                            if ($_.displayName -and -not [string]::IsNullOrWhiteSpace([string]$_.displayName)) { $name = $_.displayName }
                            elseif ($_.DisplayName -and -not [string]::IsNullOrWhiteSpace([string]$_.DisplayName)) { $name = $_.DisplayName }
                            elseif ($_.Identity) { $name = $_.Identity }

                            # Normalize AllowAnonymous bool to Yes/No/N/A
                            $allow = 'N/A'
                            if ($null -ne $_.allowAnonymousMeetingJoin) { $allow = if ($_.allowAnonymousMeetingJoin) { 'Yes' } else { 'No' } }
                            elseif ($null -ne $_.AllowAnonymousMeetingJoin) { $allow = if ($_.AllowAnonymousMeetingJoin) { 'Yes' } else { 'No' } }

                            [PSCustomObject]@{ Name = $name; AllowAnonymous = $allow }
                        }
                        $html += New-HtmlTable -Data $mpRows -Properties @('Name', 'AllowAnonymous') -Headers @('Policy', 'Allow Anonymous')
                    }
                    else {
                        $html += "<p><em>Geen meeting policies gevonden of onvoldoende permissies.</em></p>"
                    }
                }
                catch { $html += "<p><em>Kon meeting policies niet renderen.</em></p>" }
            }

            # SharePoint default link type per site
            if ($global:Phase2Data.SiteDefaultLinkTypes -and $global:Phase2Data.SiteDefaultLinkTypes.Count -gt 0) {
                $html += "<h4 style='margin-top:10px;'>🔗 SharePoint: Default Link Type per Site</h4>"
                $linkRows = $global:Phase2Data.SiteDefaultLinkTypes | ForEach-Object { [PSCustomObject]@{ Site = $_.DisplayName; DefaultLink = $_.DefaultLinkType } }
                $html += New-HtmlTable -Data $linkRows -Properties @('Site', 'DefaultLink') -Headers @('Site', 'Default Link Type')
            }

            # Teams Guest Access Settings
            if ($global:Phase2Data.GuestAccessSettings) {
                $html += "<h4 style='margin-top:10px;'>👥 Teams Guest Access</h4>"
                $guestRows = @([PSCustomObject]@{
                        Setting = "Allow Invites From Guests"
                        Value   = if ($global:Phase2Data.GuestAccessSettings.AllowInvitesFromGuests) { "Yes" } else { "No" }
                    }, [PSCustomObject]@{
                        Setting = "Allow Invites From Members" 
                        Value   = if ($global:Phase2Data.GuestAccessSettings.AllowInvitesFromMembers) { "Yes" } else { "No" }
                    })
                $html += New-HtmlTable -Data $guestRows -Properties @('Setting', 'Value') -Headers @('Setting', 'Value')
            }

        }
        
        # M365 Groups Details
        if ($global:Phase2Data.M365Groups -and $global:Phase2Data.M365Groups.Count -gt 0) {
            $html += @"
        <h3>📧 Alle M365 Groups ($($global:Phase2Data.TotalGroups))</h3>
        <p style="color: #666; font-size: 0.9em; margin-bottom: 15px;">
        <em>Inclusief Teams (elke Team heeft een onderliggende M365 Group)</em>
        </p>
"@
            $m365Data = $global:Phase2Data.M365Groups | ForEach-Object {
                [PSCustomObject]@{
                    Mail        = $_.Mail
                    DisplayName = $_.DisplayName
                    MemberCount = $_.MemberCount
                    Created     = Format-DateColumn $_.CreatedDateTime
                }
            }
            $html += New-HtmlTable -Data $m365Data -Properties @('Mail', 'DisplayName', 'MemberCount', 'Created') -Headers @('Email', 'Group Name', 'Members', 'Created')
        }
        
        $html += "</div>"  # Close M365 Groups section
        
        # Email Distribution Section
        if (($global:Phase2Data.DistributionGroups -and $global:Phase2Data.DistributionGroups.Count -gt 0) -or 
            ($global:Phase2Data.MailEnabledSecurityGroups -and $global:Phase2Data.MailEnabledSecurityGroups.Count -gt 0)) {
        
            $html += @"
        <div class="section">
        <h2 class="section-title">📨 Email Distributie</h2>
        <p style="color: #666; margin-bottom: 20px;">
        Email distribution groups en mail-enabled security groups voor het distribueren van berichten naar meerdere ontvangers.
        </p>
"@
        
            # Distribution Lists
            if ($global:Phase2Data.DistributionGroups -and $global:Phase2Data.DistributionGroups.Count -gt 0) {
                $totalMembers = ($global:Phase2Data.DistributionGroups | Measure-Object -Property MemberCount -Sum).Sum
                $html += "<h3>📧 Distribution Lists ($(SafeCount $global:Phase2Data.DistributionGroups)) - Totaal $totalMembers leden</h3>"
                $dgData = $global:Phase2Data.DistributionGroups | ForEach-Object {
                    [PSCustomObject]@{
                        Mail        = $_.Mail
                        DisplayName = $_.DisplayName
                        MemberCount = $_.MemberCount
                        Created     = Format-DateColumn $_.CreatedDateTime
                    }
                }
                $html += New-HtmlTable -Data $dgData -Properties @('Mail', 'DisplayName', 'MemberCount', 'Created') -Headers @('Email', 'Group Name', 'Members', 'Created')
            }
            else {
                $html += "<p><em>Geen distribution lists gevonden</em></p>"
            }
        
            # Mail-Enabled Security Groups
            if ($global:Phase2Data.MailEnabledSecurityGroups -and $global:Phase2Data.MailEnabledSecurityGroups.Count -gt 0) {
                $html += @"
        <h3>📬 Mail-Enabled Security Groups ($($global:Phase2Data.MailEnabledSecurityGroups.Count))</h3>
        <p style="color: #666; font-size: 0.9em; margin-bottom: 15px;">
        <em>Combinatie van security group (toegangsrechten) en email distribution</em>
        </p>
"@
                $msgData = $global:Phase2Data.MailEnabledSecurityGroups | ForEach-Object {
                    [PSCustomObject]@{
                        Mail        = $_.Mail
                        DisplayName = $_.DisplayName
                        MemberCount = $_.MemberCount
                        Created     = Format-DateColumn $_.CreatedDateTime
                    }
                }
                $html += New-HtmlTable -Data $msgData -Properties @('Mail', 'DisplayName', 'MemberCount', 'Created') -Headers @('Email', 'Group Name', 'Members', 'Created')
            }
        
            $html += "</div>"  # Close Email Distribution section
        }
        
        # Security Groups Section
        if ($global:Phase2Data.SecurityGroups -and $global:Phase2Data.SecurityGroups.Count -gt 0) {
            $html += @"
        <div class="section">
        <h2 class="section-title">🔒 Security Groups</h2>
        <p style="color: #666; margin-bottom: 20px;">
        Pure security groups gebruikt voor toegangscontrole en permissies (geen email functionaliteit).
        </p>
        <h3>🔐 Security Groups ($($global:Phase2Data.SecurityGroups.Count))</h3>
"@
            $sgData = $global:Phase2Data.SecurityGroups | ForEach-Object {
                [PSCustomObject]@{
                    DisplayName = $_.DisplayName
                    MemberCount = $_.MemberCount
                    Created     = Format-DateColumn $_.CreatedDateTime
                }
            }
            $html += New-HtmlTable -Data $sgData -Properties @('DisplayName', 'MemberCount', 'Created') -Headers @('Group Name', 'Members', 'Created')
            $html += "</div>"  # Close Security Groups section
        }
        
        # SharePoint Storage Section
        $html += @"
        <div class="section">
        <h2 class="section-title">📊 SharePoint Storage & Sites</h2>
        <p style="margin-top:6px; color:#555;"><b>Aanbeveling:</b> Beperk anonieme sharing en implementeer lifecycle policies en sensitivity labels voor zakelijke data.</p>
"@
        
        # SharePoint Sites Details with Storage
        if ($global:Phase2Data.SharePointSites -and $global:Phase2Data.SharePointSites.Count -gt 0) {
            $html += @"
        <h3>🌐 SharePoint Sites Overzicht</h3>
        <div class="stats-grid">
        <div class="stat-card">
        <div class="stat-number">$($global:Phase2Data.TotalSites)</div>
        <div class="stat-label">Totaal Sites</div>
        </div>
        <div class="stat-card">
        <div class="stat-number">$($global:Phase2Data.TotalStorageUsedGB) GB</div>
        <div class="stat-label">Totaal Storage</div>
        </div>
        <div class="stat-card">
        <div class="stat-number">$($global:Phase2Data.InactiveSites)</div>
        <div class="stat-label">Inactieve Sites (>90d)</div>
        </div>
        <div class="stat-card">
        <div class="stat-number">$($global:Phase2Data.SitesWithStorage)</div>
        <div class="stat-label">Sites met Data</div>
        </div>
        </div>
"@

            # SharePoint Tenant Settings
            if ($global:Phase2Data.SharePointTenantSettings -and $global:Phase2Data.SharePointTenantSettings -is [PSCustomObject]) {
                $html += "<h4>⚙️ SharePoint Tenant Sharing Settings</h4>"
                $spSett = $global:Phase2Data.SharePointTenantSettings
                $spRows = @(
                    [PSCustomObject]@{ Setting = "External Sharing Capability"; Value = $spSett.ExternalSharing },
                    [PSCustomObject]@{ Setting = "Default Link Permission"; Value = $spSett.DefaultLinkPermission },
                    [PSCustomObject]@{ Setting = "Loop Default Sharing Scope"; Value = $spSett.LoopDefaultSharingLinkScope }
                )
                $html += New-HtmlTable -Data $spRows -Properties @('Setting', 'Value') -Headers @('Setting', 'Value')
            }

            # Calculate SharePoint storage limits based on licenses
            # Base: 1 TB + 10 GB per license + extra for specific SKUs
            $baseStorage = 1024 # 1 TB in GB
            $storagePerLicense = 10 # GB per standard license
            
            # Get total assigned licenses and calculate storage per SKU
            $totalLicenses = 0
            $bonusStorage = 0
            $storageBreakdown = @()
            
            if ($global:Phase1Data.Licenses) {
                foreach ($lic in $global:Phase1Data.Licenses) {
                    $licCount = $lic.Consumed
                    $totalLicenses += $licCount
                    $skuName = $lic.SkuPartNumber
                    
                    # Check for SKUs with extra SharePoint storage
                    $extraStorage = 0
                    switch -Wildcard ($skuName) {
                        # Office 365 E3/E5 - extra storage
                        "*E3*" { $extraStorage = 0 } # Standard 10GB
                        "*E5*" { $extraStorage = 0 } # Standard 10GB
                        # SharePoint specific plans
                        "*SHAREPOINTSTORAGE*" { $extraStorage = $licCount * 1000 } # 1TB per license
                        "*SHAREPOINTENTERPRISE*" { $extraStorage = $licCount * 10 } # Extra 10GB
                        # OneDrive plans that include SharePoint
                        "*ONEDRIVE*" { $extraStorage = 0 } # OneDrive doesn't add SharePoint storage
                        default { $extraStorage = 0 }
                    }
                    
                    if ($extraStorage -gt 0) {
                        $bonusStorage += $extraStorage
                        $storageBreakdown += "$licCount× $skuName ( + $([math]::Round($extraStorage / $licCount, 0))GB extra)"
                    }
                }
            }
            
            # Calculate total available storage
            $totalAvailableStorage = $baseStorage + ($totalLicenses * $storagePerLicense) + $bonusStorage
            $storageUsedPercent = if ($totalAvailableStorage -gt 0) { [math]::Round(($global:Phase2Data.TotalStorageUsedGB / $totalAvailableStorage) * 100, 1) } else { 0 }
            $storageRemaining = [math]::Round($totalAvailableStorage - $global:Phase2Data.TotalStorageUsedGB, 2)
            $avgPerSite = if ($global:Phase2Data.SitesWithStorage -gt 0) { [math]::Round($global:Phase2Data.TotalStorageUsedGB / $global:Phase2Data.SitesWithStorage, 2) } else { 0 }
            
            # Determine status color for progress bar
            $statusColor = if ($storageUsedPercent -gt 80) { "#ff6600" } elseif ($storageUsedPercent -gt 60) { "#f39c12" } else { "#2ecc71" }
            
            # Build capacity label with bonus info
            $capacityLabel = "$baseStorage GB base + $totalLicenses licenses × $storagePerLicense GB"
            if ($bonusStorage -gt 0) {
                $capacityLabel += " + $([math]::Round($bonusStorage,0)) GB bonus"
            }
            
            $html += @"
                <h4>📊 SharePoint Storage Capacity & License Analysis</h4>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number">$totalAvailableStorage GB</div>
                        <div class="stat-label">📦 Totaal Capaciteit</div>
                        <span class="stat-small">$capacityLabel</span>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase2Data.TotalStorageUsedGB) GB</div>
                        <div class="stat-label">💾 Gebruikt</div>
                        <span class="stat-small">$storageUsedPercent% van capaciteit</span>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$storageRemaining GB</div>
                        <div class="stat-label">✅ Beschikbaar</div>
                        <span class="stat-small">$(100 - $storageUsedPercent)% vrij</span>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$avgPerSite GB</div>
                        <div class="stat-label">📈 Gemiddeld/Site</div>
                        <span class="stat-small">$($global:Phase2Data.SitesWithStorage) sites met data</span>
                    </div>
                </div>
                
                <div class="alert alert-info">
                    <h5 style="margin-top: 0;">Storage Gebruik Visualisatie</h5>
                    <div class="progress-container">
                        <div class="progress-bar" style="width: $storageUsedPercent%; background: linear-gradient(90deg, $statusColor, $(if($storageUsedPercent -gt 80){'#c0392b'}elseif($storageUsedPercent -gt 60){'#e67e22'}else{'#27ae60'}));">
                            $storageUsedPercent%
                        </div>
                    </div>
                    <div style="display: flex; justify-content: space-between; font-size: 12px; color: #7f8c8d; margin-top: 5px;">
                        <span>$($global:Phase2Data.TotalStorageUsedGB) GB gebruikt</span>
                        <span>$totalAvailableStorage GB totaal</span>
                    </div>
                </div>
"@
            
            # Status message based on usage
            if ($storageUsedPercent -gt 80) {
                $html += @"
                <div class="recommendation" style="border-left-color: #ff6600; background: #fee;">
                    <h5 style="margin-top: 0; color: #ff6600;">⚠️ WAARSCHUWING: Hoog Storage Gebruik</h5>
                    <p><strong>Storage gebruik is $storageUsedPercent%</strong> - dit is kritiek!</p>
                    <p><strong><b>Aanbevelingen</b></strong></p>
                    <ul>
                        <li>Voer storage cleanup uit op grote/inactieve sites</li>
                        <li>Overweeg extra Microsoft 365 licenties (elke licentie = +10 GB)</li>
                        <li>Implementeer data archivering policies</li>
                        <li>Check SharePoint Admin Center voor exacte quota</li>
                    </ul>
                </div>
"@
            }
            elseif ($storageUsedPercent -gt 60) {
                $html += @"
                <div class="recommendation" style="border-left-color: #f39c12; background: #fef9e6;">
                    <h5 style="margin-top: 0; color: #f39c12;">⚠️ LET OP: Storage Gebruik Monitoren</h5>
                    <p><strong>Storage gebruik is $storageUsedPercent%</strong> - monitor de groei.</p>
                    <p><strong><b>Aanbevelingen</b></strong></p>
                    <ul>
                        <li>Monitor storage trends maandelijks</li>
                        <li>Identificeer grote of snel groeiende sites</li>
                        <li>Plan voor toekomstige storage needs</li>
                    </ul>
                </div>
"@
            }
            else {
                $html += @"
                <div style="background: #eafaf1; border-left: 4px solid #2ecc71; padding: 15px; margin: 20px 0; border-radius: 4px;">
                    <h5 style="margin-top: 0; color: #27ae60;">✅ GOED: Voldoende Storage Capaciteit</h5>
                    <p><strong>Storage gebruik is $storageUsedPercent%</strong> - ruim voldoende capaciteit beschikbaar.</p>
                    <p>Huidige storage beheer is gezond. Continue monitoring aanbevolen.</p>
                </div>
"@
            }
            
            # Determine SharePoint Admin URL dynamically
            $spAdminUrl = "https://portal.office.com/Partner/BeginClientSession.aspx?CTID=$($global:TenantInfo.TenantId)&CSDEST=SharePoint"
            if ($global:Phase2Data.SharePointSites -and $global:Phase2Data.SharePointSites.Count -gt 0) {
                $firstSiteUrl = $global:Phase2Data.SharePointSites[0].WebUrl
                if ($firstSiteUrl -match 'https://([^/]+)') {
                    $tenantDomain = $matches[1] -replace '\.sharepoint\.com.*', ''
                    $spAdminUrl = "https://$tenantDomain-admin.sharepoint.com"
                }
            }
            
            $html += @"
                <div class="alert alert-info" style="margin: 15px 0;">
                    <p style="margin: 0; font-size: 13px;">
                        <strong>💡 Note:</strong> Deze berekening gebruikt de vereenvoudigde formule: <code>1 TB + (licenses × 10 GB)</code>. 
                        Exacte quota kan verschillen per tenant type en licentie mix. 
                        Controleer <a href="$spAdminUrl" target="_blank">SharePoint Admin Center</a> voor exacte quota.
                    </p>
                </div>
"@
            
            # Top 10 grootste sites
            if ($global:Phase2Data.Top10Sites -and $global:Phase2Data.Top10Sites.Count -gt 0) {
                $html += @"
                <h4>📊 Top 10 Grootste Sites</h4>
                <div class="table-container">
                <table>
                    <thead>
                        <tr><th>Site Name</th><th>Storage (GB)</th><th>Status</th><th>Last Modified</th></tr>
                    </thead>
                    <tbody>
"@
                foreach ($site in $global:Phase2Data.Top10Sites) {
                    $modified = if ($site.LastModifiedDateTime) { $site.LastModifiedDateTime.ToString('dd-MM-yyyy') } else { 'N/A' }
                    $statusClass = if ($site.IsInactive) { "status-error" } else { "status-success" }
                    $statusText = if ($site.IsInactive) { "⚠️ Inactief ($($site.DaysSinceModified)d)" } else { "✓ Actief" }
                    $storageDisplay = if ($site.StorageUsedGB -gt 0) { $site.StorageUsedGB } else { "0" }
                    $html += "<tr><td><a href='$($site.WebUrl)'>$($site.DisplayName)</a></td><td>$storageDisplay</td><td class='$statusClass'>$statusText</td><td>$modified</td></tr>"
                }
                $html += "</table></div>"
            }
            
            # Top 5 grootste OneDrive
            if ($global:Phase2Data.Top5OneDriveBySize -and $global:Phase2Data.Top5OneDriveBySize.Count -gt 0) {
                $html += @"
                <h4>📊 Top 5 Grootste OneDrive Sites</h4>
                <p style="color: #666; margin-bottom: 10px;">
                    Totaal: $($global:Phase2Data.TotalOneDrives) OneDrives | Storage: $($global:Phase2Data.TotalOneDriveStorageGB) GB
                </p>
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Owner</th><th>Storage (GB)</th><th>Last Modified</th></tr>
                    </thead>
                    <tbody>
"@
                foreach ($oneDrive in $global:Phase2Data.Top5OneDriveBySize) {
                    $modified = if ($oneDrive.LastModifiedDateTime) { $oneDrive.LastModifiedDateTime.ToString('dd-MM-yyyy') } else { 'N/A' }
                    $storageDisplay = if ($oneDrive.StorageUsedGB -gt 0) { $oneDrive.StorageUsedGB } else { "0" }
                    $html += "<tr><td>$($oneDrive.Owner)</td><td>$storageDisplay</td><td>$modified</td></tr>"
                }
                $html += "</table></div>"
            }
            
            # Aanbevelingen voor SharePoint
            $recommendations = @()
            
            if ($global:Phase2Data.InactiveSites -gt 0) {
                $recommendations += "Er zijn <strong>$($global:Phase2Data.InactiveSites) inactieve sites</strong> gevonden (>90 dagen niet gewijzigd). Overweeg deze sites te archiveren of te verwijderen."
            }
            
            if ($global:Phase2Data.TotalStorageUsedGB -gt 1000) {
                $recommendations += "Totaal storage verbruik is <strong>$($global:Phase2Data.TotalStorageUsedGB) GB</strong>. Controleer of storage optimalisatie nodig is."
            }
            
            # Check for very large sites
            $largeSites = $global:Phase2Data.SharePointSites | Where-Object { $_.StorageUsedGB -gt 100 }
            if ($largeSites.Count -gt 0) {
                $recommendations += "<strong>$($largeSites.Count) sites</strong> gebruiken meer dan 100 GB storage. Overweeg data archivering of opschoning."
            }
            
            # Check for old inactive sites with storage
            $wasteFullSites = $global:Phase2Data.SharePointSites | Where-Object { $_.IsInactive -eq $true -and $_.StorageUsedGB -gt 10 }
            if ($wasteFullSites.Count -gt 0) {
                $totalWaste = [math]::Round(($wasteFullSites | Measure-Object -Property StorageUsedGB -Sum).Sum, 2)
                $recommendations += "<strong>$($wasteFullSites.Count) inactieve sites</strong> met data (totaal $totalWaste GB) kunnen opgeschoond worden om storage te besparen."
            }
            
            if ($global:Phase2Data.TotalSites -gt 100) {
                $recommendations += "Er zijn <strong>$($global:Phase2Data.TotalSites) SharePoint sites</strong> in de tenant. Overweeg een governance policy voor site creatie en lifecycle management."
            }
            
            if ($recommendations.Count -eq 0) {
                $recommendations += "✅ SharePoint sites zien er goed uit. Geen directe aanbevelingen."
            }
            
            $html += @"
                <div class="recommendation">
                    <h4>💡 Aanbevelingen SharePoint Sites</h4>
                    <ul>
"@
            foreach ($rec in $recommendations) {
                $html += "<li>$rec</li>"
            }
            $html += @"
                    </ul>
                </div>
            </div>
"@
        }
        
        # Exchange Online Mailboxes Section (NO distribution groups - those are in Email Distribution section)
        $html += @"
            <div class="section">
                <h2 class="section-title">📬 Exchange Online Mailboxen</h2>
                <p style="color: #666; margin-bottom: 20px;">
                    User mailboxen, shared mailboxen en resource mailboxen (vergaderruimtes en apparatuur).
                </p>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase2Data.UserMailboxes.Count)</div>
                        <div class="stat-label">User Mailboxes</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase2Data.SharedMailboxes.Count)</div>
                        <div class="stat-label">Shared Mailboxes</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase2Data.RoomMailboxes.Count)</div>
                        <div class="stat-label">Room Mailboxes</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase2Data.EquipmentMailboxes.Count)</div>
                        <div class="stat-label">Equipment Mailboxes</div>
                    </div>
                </div>
"@
        
        # User Mailboxes
        if ($global:Phase2Data.UserMailboxes -and $global:Phase2Data.UserMailboxes.Count -gt 0) {
            $html += "<h3>👤 User Mailboxes ($($global:Phase2Data.UserMailboxes.Count))</h3>"
            $mbxData = $global:Phase2Data.UserMailboxes | ForEach-Object {
                [PSCustomObject]@{
                    Email       = $_.PrimarySmtpAddress
                    DisplayName = $_.DisplayName
                    Created     = Format-DateColumn $_.WhenCreated
                }
            }
            $html += New-HtmlTable -Data $mbxData -Properties @('Email', 'DisplayName', 'Created') -Headers @('Email Address', 'Display Name', 'Created')
        }
        
        # Shared Mailboxes
        if ($global:Phase2Data.SharedMailboxes -and $global:Phase2Data.SharedMailboxes.Count -gt 0) {
            $html += "<h3>📮 Shared Mailboxes ($($global:Phase2Data.SharedMailboxes.Count))</h3>"
            $sharedMbxData = $global:Phase2Data.SharedMailboxes | ForEach-Object {
                $fullAccessCount = if ($_.FullAccessUsers) { ($_.FullAccessUsers -split ',').Count } else { 0 }
                $sendAsCount = if ($_.SendAsUsers) { ($_.SendAsUsers -split ',').Count } else { 0 }
                $sendOnBehalfCount = if ($_.SendOnBehalfUsers) { ($_.SendOnBehalfUsers -split ',').Count } else { 0 }
                
                [PSCustomObject]@{
                    Email        = $_.PrimarySmtpAddress
                    DisplayName  = $_.DisplayName
                    FullAccess   = $fullAccessCount
                    SendAs       = $sendAsCount
                    SendOnBehalf = $sendOnBehalfCount
                    Created      = Format-DateColumn $_.WhenCreated
                }
            }
            $html += New-HtmlTable -Data $sharedMbxData -Properties @('Email', 'DisplayName', 'FullAccess', 'SendAs', 'SendOnBehalf', 'Created') -Headers @('Email Address', 'Display Name', 'Full Access', 'Send As', 'Send On Behalf', 'Created')
        }
        
        # Room Mailboxes
        if ($global:Phase2Data.RoomMailboxes -and $global:Phase2Data.RoomMailboxes.Count -gt 0) {
            $html += "<h3>🏢 Room Mailboxes ($($global:Phase2Data.RoomMailboxes.Count))</h3>"
            $roomData = $global:Phase2Data.RoomMailboxes | ForEach-Object {
                [PSCustomObject]@{
                    Email       = $_.PrimarySmtpAddress
                    DisplayName = $_.DisplayName
                    Created     = Format-DateColumn $_.WhenCreated
                }
            }
            $html += New-HtmlTable -Data $roomData -Properties @('Email', 'DisplayName', 'Created') -Headers @('Email Address', 'Display Name', 'Created')
        }
        
        # Equipment Mailboxes
        if ($global:Phase2Data.EquipmentMailboxes -and $global:Phase2Data.EquipmentMailboxes.Count -gt 0) {
            $html += "<h3>🖨️ Equipment Mailboxes ($($global:Phase2Data.EquipmentMailboxes.Count))</h3>"
            $eqData = $global:Phase2Data.EquipmentMailboxes | ForEach-Object {
                [PSCustomObject]@{
                    Email       = $_.PrimarySmtpAddress
                    DisplayName = $_.DisplayName
                    Created     = Format-DateColumn $_.WhenCreated
                }
            }
            $html += New-HtmlTable -Data $eqData -Properties @('Email', 'DisplayName', 'Created') -Headers @('Email Address', 'Display Name', 'Created')
        }
        
        # NO Distribution Groups or Mail-Enabled Security Groups here!
        # They are already shown in the "Email Distributie" section above
        
        # Top 5 Mailboxes by Size
        if ($global:Phase2Data.Top5MailboxesBySize -and $global:Phase2Data.Top5MailboxesBySize.Count -gt 0) {
            $html += "<h3>📊 Top 5 Grootste Mailboxen</h3>"
            $top5MbxData = $global:Phase2Data.Top5MailboxesBySize | Select-Object @{N = 'Email'; E = { $_.PrimarySmtpAddress } }, DisplayName, @{N = 'SizeGB'; E = { "$($_.SizeInGB) GB" } }, TotalItemSize
            $html += New-HtmlTable -Data $top5MbxData -Properties @('Email', 'DisplayName', 'SizeGB', 'TotalItemSize') -Headers @('Email Address', 'Display Name', 'Size (GB)', 'Total Size')
        }
        
        $html += "</div>"  # Close Exchange Online section

        # Exchange Security & DNS Section (New)
        $html += @"
            <div class="section">
                <h2 class="section-title">🛡️ Exchange Security & DNS</h2>
                <p style='margin-top:6px; color:#555;'><b>Aanbeveling:</b> Schakel tenant-brede moderne authenticatie in, blokkeer legacy protocols (SMTP/IMAP/POP) waar mogelijk en activeer DKIM/DMARC voor alle geclaimde domeinen.</p>
"@
        
        # Security Settings
        if ($global:Phase2Data.ExchangeSecurity) {
            $es = $global:Phase2Data.ExchangeSecurity
            $html += "<h3>Authentication & Protocols</h3>"
            $secRows = @()
            if ($null -ne $es.ModernAuthEnabled) {
                $secRows += [PSCustomObject]@{ Setting = "Modern Authentication Enabled"; Value = if ($es.ModernAuthEnabled) { "✅ Yes" } else { "❌ No" } }
            }
            if ($null -ne $es.SmtpClientAuthenticationDisabled) {
                $secRows += [PSCustomObject]@{ Setting = "SMTP Client Auth Disabled (Tenant)"; Value = if ($es.SmtpClientAuthenticationDisabled) { "✅ Yes" } else { "⚠️ No" } }
            }
            if ($null -ne $es.LegacyAuthProtocols) {
                $secRows += [PSCustomObject]@{ Setting = "Legacy Auth Protocols Blocked (ActivityBased)"; Value = if ($es.LegacyAuthProtocols) { "✅ Yes" } else { "⚠️ No" } }
            }
            
            if ($secRows.Count -gt 0) {
                $html += New-HtmlTable -Data $secRows -Properties @('Setting', 'Value') -Headers @('Setting', 'Status')
            }
        }

        # DNS Records
        if ($global:Phase2Data.DnsRecords -and $global:Phase2Data.DnsRecords.Count -gt 0) {
            $html += "<h3>DNS Records (SPF/DKIM/DMARC)</h3>"
            $dnsTable = New-HtmlTable -Data $global:Phase2Data.DnsRecords -Properties @('Domain', 'SPF', 'DMARC', 'DKIM') -Headers @('Domain', 'SPF', 'DMARC', 'DKIM')
            $html += $dnsTable
        }
        
        $html += "</div>" # Close Exchange Security section

        
        # Directory Roles Section
        $html += @"
            <div class="section">
                <h2 class="section-title">👑 Directory Roles & Permissions</h2>
"@
        
        if ($global:Phase2Data.RoleAssignments -and $global:Phase2Data.RoleAssignments.Count -gt 0) {
            # Group by role
            $roleGroups = $global:Phase2Data.RoleAssignments | Group-Object -Property RoleName
            
            foreach ($roleGroup in $roleGroups | Sort-Object Name) {
                $html += @"
                <h3>🎭 $($roleGroup.Name) ($($roleGroup.Count) gebruiker$(if($roleGroup.Count -ne 1){'s'}))</h3>
                <div class="table-container">
                <table>
                    <thead>
                        <tr><th>User Principal Name</th><th>Display Name</th></tr>
                    </thead>
                    <tbody>
"@
                foreach ($assignment in $roleGroup.Group) {
                    $html += "<tr><td>$($assignment.UserPrincipalName)</td><td>$($assignment.DisplayName)</td></tr>"
                }
                $html += "</table></div>"
            }
        }
        else {
            $html += "<p>Geen role assignments gevonden.</p>"
        }
        
        # Close directory roles section before adding recommendations
        $html += "</div>"
        # Close Phase 2 body wrapper
        $html += "</div> <!-- End Phase Body -->"
        
        # PHASE 2 RECOMMENDATIONS - At the end of the phase
        $html += @"
            <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
                <h2 class="section-title">💡 Aanbevelingen - Phase 2: Collaboration & Storage</h2>
                <p style="margin-bottom: 20px; color: #666;">Microsoft best practices voor Teams, SharePoint, OneDrive en Exchange collaboration:</p>
"@
        
        $phase2Recs = @()
        
        $oldTeams = $global:Phase2Data.Teams | Where-Object { 
            $_.CreatedDateTime -and ((Get-Date) - $_.CreatedDateTime).Days -gt 365 
        }
        if ($oldTeams) {
            $phase2Recs += New-HtmlAlert -Type info -Message "<strong>📅 Team Lifecycle Management:</strong> $($oldTeams.Count) team(s) zijn ouder dan 1 jaar. <br><strong>Microsoft Best Practice:</strong> Implementeer Microsoft 365 Groups expiration policy (aanbevolen: 365 dagen). Gebruik access reviews om inactieve teams automatisch te detecteren en op te schonen."
        }
        
        $emptyGroups = $global:Phase2Data.AllGroups | Where-Object { $_.MemberCount -eq 0 }
        if ($emptyGroups) {
            $phase2Recs += New-HtmlAlert -Type warning -Message "<strong>👥 Lege Groepen:</strong> $($emptyGroups.Count) groep(en) zonder leden gedetecteerd. <br><strong>Microsoft Best Practice:</strong> Configureer automatische cleanup van lege groepen na 30 dagen. Gebruik PowerShell scripts of Azure Automation voor regelmatige cleanup."
        }
        
        $largeGroups = $global:Phase2Data.AllGroups | Where-Object { $_.MemberCount -gt 100 }
        if ($largeGroups) {
            $phase2Recs += New-HtmlAlert -Type info -Message "<strong>📊 Grote Groepen ($($largeGroups.Count)):</strong> <br><strong>Microsoft Best Practice:</strong> Overweeg gebruik van Dynamic Groups voor grote groepen. Implementeer Teams governance policy voor team size limits en channel structuur. Voor organisatie-brede communicatie, gebruik Yammer/Viva Engage."
        }
        
        $emptyDistGroups = $global:Phase2Data.DistributionGroups | Where-Object { $_.MemberCount -eq 0 }
        if ($emptyDistGroups) {
            $phase2Recs += New-HtmlAlert -Type warning -Message "<strong>📧 Lege Distribution Groups:</strong> $($emptyDistGroups.Count) distribution group(s) zonder leden. <br><strong>Microsoft Best Practice:</strong> Migreer distribution lists naar M365 Groups waar mogelijk voor betere collaboration features (shared calendar, files, etc.)."
        }
        
        $rolesByUser = $global:Phase2Data.RoleAssignments | Group-Object -Property UserPrincipalName | Where-Object { ($_ | Select-Object -First 1).Count -gt 2 }
        if ($rolesByUser) {
            $phase2Recs += New-HtmlAlert -Type info -Message "<strong>👑 Gebruikers met Meerdere Rollen:</strong> $($rolesByUser.Count) gebruiker(s) hebben meer dan 2 admin rollen. <br><strong>Microsoft Best Practice:</strong> Volg principe van least privilege. Gebruik Privileged Identity Management (PIM) voor just-in-time admin toegang. Review role assignments elk kwartaal."
        }
        
        $highPrivRoles = $global:Phase2Data.RoleAssignments | Where-Object { 
            $_.RoleName -match 'Global Administrator|Security Administrator|Exchange Administrator|SharePoint Administrator' 
        }
        if ($highPrivRoles.Count -gt 5) {
            $phase2Recs += New-HtmlAlert -Type warning -Message "<strong>⚠️ Veel Admin Accounts:</strong> $($highPrivRoles.Count) hoog-privilege rol toewijzingen. <br><strong>Microsoft Best Practice:</strong> Beperk aantal admins tot minimum. Gebruik specifieke admin rollen (SharePoint Admin, Teams Admin) in plaats van Global Admin waar mogelijk."
        }
        
        if ((SafeCount $phase2Recs) -eq 0) {
            $phase2Recs += New-HtmlAlert -Type success -Message "<strong>✅ Geen kritieke issues gevonden in Phase 2</strong>"
        }
        
        $html += @"
                <div style="margin-top: 15px;">
"@
        foreach ($rec in $phase2Recs) {
            $html += "                    $rec"
        }
        
        $html += @"
                </div>
                
                <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
                    <h4 style="margin-top: 0;">📋 Algemene Best Practices - Phase 2</h4>
                    <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
                        <li><strong>Teams Governance:</strong> Implementeer naming conventions, classification labels en expiration policies voor Teams</li>
                        <li><strong>SharePoint Storage:</strong> Gebruik storage quotas per site. Implementeer retention policies voor automatische archivering</li>
                        <li><strong>External Sharing:</strong> Beperk external sharing tot approved domains. Gebruik sensitivity labels voor classificatie</li>
                        <li><strong>OneDrive Sync:</strong> Configureer Known Folder Move (KFM) voor Desktop/Documents/Pictures backup</li>
                        <li><strong>Exchange Rules:</strong> Monitor forwarding rules voor data leakage prevention. Disable auto-forwarding to external domains</li>
                        <li><strong>Access Reviews:</strong> Implementeer quarterly reviews voor teams en groups membership</li>
                        <li><strong>Retention Policies:</strong> Configureer retention labels voor compliance en data lifecycle management</li>
                    </ul>
                </div>
            </div>
"@
        $html += "    </div>"  # Close phase2
    }
    
    # PHASE 3 CONTENT
    if (-not $SkipPhase3) {
        $secDefaultStatus = if ($global:Phase3Data.SecurityDefaultsEnabled) { "✓ Enabled" } else { "✗ Disabled" }
        $auditStatus = if ($global:Phase3Data.AuditEnabled) { "✓ Enabled" } else { "✗ Disabled" }
        
        $html += @"
        <div id="phase3" class="phase-content">
            <h1>⚖️ Compliance</h1>
            <div class="section">
                <h2 class="section-title">🛡️ Security & Compliance Status</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase3Data.CAEnabled)</div>
                        <div class="stat-label">CA Policies Enabled</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase3Data.CADisabled)</div>
                        <div class="stat-label">CA Policies Disabled</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$secDefaultStatus</div>
                        <div class="stat-label">Security Defaults</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$auditStatus</div>
                        <div class="stat-label">Audit Logging</div>
                    </div>
                </div>
"@
        
        # CA Policies Details
        if ($global:Phase3Data.CAPolicies -and (SafeCount $global:Phase3Data.CAPolicies) -gt 0) {
            $html += "<h3>🛡️ Conditional Access Policies ($(SafeCount $global:Phase3Data.CAPolicies))</h3>"
            $html += "<div style='max-height: 500px; overflow-y: auto; border: 1px solid #e5e9f0; border-radius: 4px;'><table style='margin: 0;'>"
            $html += "<thead><tr><th>Policy Name</th><th>State</th><th>Created</th></tr></thead><tbody>"
            foreach ($policy in $global:Phase3Data.CAPolicies) {
                $state = $policy.State
                $stateColor = if ($state -eq 'enabled') { 'color: green;' } else { 'color: orange;' }
                $created = Format-DateColumn $policy.CreatedDateTime
                $html += "<tr><td>$($policy.DisplayName)</td><td style='$stateColor'><strong>$state</strong></td><td>$created</td></tr>"
            }
            $html += "</tbody></table></div>"
            $html += "            </div>"  # Close CA policies section
        }
        # Domain email auth checks (SPF/DKIM/DMARC)
        if ($global:Phase3Data.DomainDnsChecks -and $global:Phase3Data.DomainDnsChecks.Count -gt 0) {
            $html += "<div class='section'><h3>📬 Domain Email Authentication (SPF/DKIM/DMARC)</h3>"
            $dnsRows = $global:Phase3Data.DomainDnsChecks | ForEach-Object { [PSCustomObject]@{ Domain = $_.Domain; SPF = ($_.SPF -or $_.Spf -or 'Unknown'); DKIM = ($_.DKIM -or $_.Dkim -or 'Unknown'); DMARC = ($_.DMARC -or $_.Dmarc -or 'Unknown') } }
            $html += New-HtmlTable -Data $dnsRows -Properties @('Domain', 'SPF', 'DKIM', 'DMARC') -Headers @('Domain', 'SPF', 'DKIM', 'DMARC')
            $html += "</div>"
        }
        
        # App Registrations Section (as part of Phase 3)
        if ($global:Phase3Data.AppRegistrations) {
            $html += @"
            
            <div id="appregs" class="section">
                <h2 class="section-title" style="margin-top: 40px;">🔐 App Registrations</h2>
                <h3 style="margin-top: 20px;">📊 Overzicht</h3>
                
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase3Data.AppRegistrationCount)</div>
                        <div class="stat-label">Totaal Apps</div>
                    </div>
                    <div class="stat-card stat-card--danger">
                        <div class="stat-number">$($global:Phase3Data.AppRegsWithExpiredSecrets + $global:Phase3Data.AppRegsWithExpiredCerts)</div>
                        <div class="stat-label">Verlopen Credentials</div>
                    </div>
                    <div class="stat-card stat-card--warning">
                        <div class="stat-number">$($global:Phase3Data.AppRegsWithExpiringSecrets + $global:Phase3Data.AppRegsWithExpiringCerts)</div>
                        <div class="stat-label">Verlopen Binnenkort</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$(($global:Phase3Data.AppRegistrations | Where-Object { $_.HasEnterpriseApp }).Count)</div>
                        <div class="stat-label">Met Enterprise App</div>
                    </div>
                </div>
"@

            # Warnings for expired/expiring credentials
            $totalExpired = $global:Phase3Data.AppRegsWithExpiredSecrets + $global:Phase3Data.AppRegsWithExpiredCerts
            $totalExpiring = $global:Phase3Data.AppRegsWithExpiringSecrets + $global:Phase3Data.AppRegsWithExpiringCerts
            
            if ($totalExpired -gt 0) {
                $html += @"
                <div class="alert alert-critical" style="margin-top: 20px;">
                    <strong>⚠️ KRITIEK: Verlopen Credentials</strong><br>
                    $totalExpired credential(s) zijn verlopen! Deze apps kunnen geen API calls meer maken. Vernieuw de secrets/certificates onmiddellijk.
                </div>
"@
            }
            
            if ($totalExpiring -gt 0) {
                $html += @"
                <div class="alert alert-warning" style="margin-top: 20px;">
                    <strong>⚠️ WAARSCHUWING: Credentials Verlopen Binnenkort</strong><br>
                    $totalExpiring credential(s) verlopen binnen 30 dagen. Plan credential renewal in om service onderbreking te voorkomen.
                </div>
"@
            }
            
            # App Registrations Table
            $html += @"
                <h3 style="margin-top: 30px; margin-bottom: 15px;">App Registrations Details</h3>
                
                <div class="table-container">
                <table>
                    <thead>
                        <tr>
                            <th>App Naam</th>
                            <th>Aangemaakt</th>
                            <th>Secrets</th>
                            <th>Certificates</th>
                            <th>Permissions</th>
                        </tr>
                    </thead>
                    <tbody>
"@

            # Sort by expiration (expired first, then expiring soon, then by name)
            $sortedAppRegs = $global:Phase3Data.AppRegistrations | Sort-Object -Property @(
                @{Expression = { ($_.SecretExpirationStatus -like '*Expired*') -or ($_.CertificateExpirationStatus -like '*Expired*') }; Descending = $true },
                @{Expression = { ($_.SecretExpirationStatus -like '*soon*') -or ($_.CertificateExpirationStatus -like '*soon*') }; Descending = $true },
                @{Expression = { $_.DisplayName } }
            )
        
            foreach ($appReg in $sortedAppRegs) {
                $createdDate = if ($appReg.CreatedDateTime) { 
                    ([datetime]$appReg.CreatedDateTime).ToString('dd-MM-yyyy') 
                }
                else { 
                    'N/A' 
                }
            
                # Row color based on expiration status
                $rowStyle = ""
                if (($appReg.SecretExpirationStatus -like '*Expired*') -or ($appReg.CertificateExpirationStatus -like '*Expired*')) {
                    $rowStyle = "background: #fee;"
                }
                elseif (($appReg.SecretExpirationStatus -like '*soon*') -or ($appReg.CertificateExpirationStatus -like '*soon*')) {
                    $rowStyle = "background: #fffbf0;"
                }
            
                $html += "<tr style='border-bottom: 1px solid #e5e9f0; $rowStyle'>"
                $html += "<td style='padding: 12px; font-weight: 500;'>$([System.Web.HttpUtility]::HtmlEncode($appReg.DisplayName))</td>"
                $html += "<td style='padding: 12px; color: #666;'>$createdDate</td>"
            
                # Secrets column
                $html += "<td style='padding: 12px;'>"
                $html += "<strong>$($appReg.SecretCount) secret(s)</strong><br>"
                $html += "<span style='font-weight: 500; font-size: 0.9em;'>$($appReg.SecretExpirationStatus)</span>"
                if ($appReg.SecretExpiration) {
                    $secretDate = ([datetime]$appReg.SecretExpiration).ToString('dd-MM-yyyy')
                    $html += "<br><span style='font-size: 0.85em; color: #666;'>$secretDate</span>"
                }
                $html += "</td>"
            
                # Certificates column
                $html += "<td style='padding: 12px;'>"
                $html += "<strong>$($appReg.CertificateCount) cert(s)</strong><br>"
                $html += "<span style='font-weight: 500; font-size: 0.9em;'>$($appReg.CertificateExpirationStatus)</span>"
                if ($appReg.CertificateExpiration) {
                    $certDate = ([datetime]$appReg.CertificateExpiration).ToString('dd-MM-yyyy')
                    $html += "<br><span style='font-size: 0.85em; color: #666;'>$certDate</span>"
                }
                $html += "</td>"
            
                # Permissions column
                $html += "<td style='padding: 12px;'>"
                if ($appReg.Permissions.Count -eq 0) {
                    if ($appReg.HasEnterpriseApp) {
                        $html += "<span style='color: #999;'>Geen permissions</span>"
                    }
                    else {
                        $html += "<span style='color: #999;'>Geen Enterprise App</span>"
                    }
                }
                else {
                    $html += "<strong>$($appReg.Permissions.Count) permissions</strong><br>"
                    $html += "<div style='max-height: 100px; overflow-y: auto; font-size: 0.85em; margin-top: 5px;'>"
                
                    # Group by resource
                    $permsByResource = $appReg.Permissions | Group-Object -Property Resource
                    foreach ($resource in $permsByResource) {
                        $resourceName = if ($resource.Name) { $resource.Name } else { "Unknown" }
                        $html += "<div style='margin-bottom: 5px;'>"
                        $html += "<strong style='color: #0066b3; font-size: 0.9em;'>$([System.Web.HttpUtility]::HtmlEncode($resourceName)):</strong><br>"
                    
                        foreach ($perm in $resource.Group | Select-Object -First 3) {
                            $permType = if ($perm.Type -eq 'Application') { 'App' } else { 'Del' }
                            $typeColor = if ($perm.Type -eq 'Application') { '#ff6600' } else { '#3498db' }
                            $html += "<span style='color: $typeColor; font-size: 0.8em; margin-left: 8px;'>[$permType]</span> "
                            $html += "<span style='color: #555; font-size: 0.85em;'>$([System.Web.HttpUtility]::HtmlEncode($perm.Permission))</span><br>"
                        }
                    
                        if ($resource.Group.Count -gt 3) {
                            $html += "<span style='color: #999; font-size: 0.8em; margin-left: 8px;'>... +$($resource.Group.Count - 3) more</span><br>"
                        }
                        $html += "</div>"
                    }
                    $html += "</div>"
                }
                $html += "</td>"

            }
        
            $html += @"
                </tbody>
            </table>
            </div>
            
            <div style="margin-top: 30px; padding: 15px; background: #f0f8ff; border-left: 4px solid #3498db; border-radius: 4px;">
                <h5 style="margin-top: 0;">ℹ️ Over App Registrations</h5>
                <ul style="margin: 10px 0 0 20px; color: #555;">
                    <li><strong>App Registrations:</strong> Jouw eigen apps geregistreerd in deze tenant</li>
                    <li><strong>Secrets vs Certificates:</strong> Gebruik bij voorkeur certificates (hogere security)</li>
                    <li><strong>Enterprise App:</strong> Als deze bestaat kan de app permissions krijgen en gebruikt worden</li>
                    <li><strong>Credential Monitoring:</strong> Monitor expiratie van secrets én certificates</li>
                    <li><strong>Best Practice:</strong> Roteer secrets minimaal elke 6 maanden, certificates elk jaar</li>
                </ul>
            </div>
            </div>
"@
        }

        # PHASE 3 RECOMMENDATIONS - At the end of the phase
        $html += @"
            <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
                <h2 class="section-title">💡 Aanbevelingen - Phase 3: Compliance & Security Policies</h2>
                <p style="margin-bottom: 20px; color: #666;">Microsoft best practices voor Conditional Access, DLP, retention en audit logging:</p>
"@
        
        # Recommendations Phase 3
        $phase3Recs = @()
        
        if ($global:Phase3Data.CAEnabled -eq 0) {
            $phase3Recs += New-HtmlAlert -Type critical -Message "<strong>🛡️ Conditional Access (Critical):</strong> Geen actieve CA policies gedetecteerd. <br><strong>Microsoft Best Practice:</strong> Implementeer minimaal: (1) Require MFA for all users, (2) Block legacy authentication, (3) Require compliant/hybrid joined device for admins, (4) Require MFA for Azure management, (5) Block access from untrusted locations."
        }
        elseif ($global:Phase3Data.CADisabled -gt 0) {
            $phase3Recs += New-HtmlAlert -Type info -Message "<strong>🛡️ Disabled CA Policies:</strong> $($global:Phase3Data.CADisabled) CA policy/policies zijn disabled. <br><strong>Microsoft Best Practice:</strong> Review disabled policies quarterly. Verwijder policies die niet meer nodig zijn om configuratie overzichtelijk te houden."
        }
        
        if (-not $global:Phase3Data.SecurityDefaultsEnabled -and $global:Phase3Data.CAEnabled -lt 3) {
            $phase3Recs += New-HtmlAlert -Type warning -Message "<strong>🔐 Security Defaults:</strong> Security Defaults zijn niet actief en weinig CA policies geconfigureerd. <br><strong>Microsoft Best Practice:</strong> Schakel Security Defaults in VOOR kleine tenants zonder P1/P2 licenties, of implementeer comprehensive CA policy set voor P1/P2 tenants."
        }
        
        if (-not $global:Phase3Data.AuditEnabled) {
            $phase3Recs += New-HtmlAlert -Type critical -Message "<strong>📋 Audit Logging (Critical):</strong> Audit logging is niet actief. <br><strong>Microsoft Best Practice:</strong> Schakel Unified Audit Log in. Configureer audit log retention van minimaal 90 dagen (365 dagen voor compliance). Gebruik Azure Monitor of SIEM voor long-term retention en alerting."
        }
        
        if ($phase3Recs.Count -eq 0) {
            $phase3Recs += New-HtmlAlert -Type success -Message "<strong>✅ Geen kritieke issues gevonden in Phase 3</strong>"
        }
        
        $html += @"
                <div style="margin-top: 15px;">
"@
        foreach ($rec in $phase3Recs) {
            $html += "                    $rec"
        }
        
        $html += @"
                </div>
                
                <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
                    <h4 style="margin-top: 0;">📋 Algemene Best Practices - Phase 3</h4>
                    <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
                        <li><strong>Conditional Access:</strong> Gebruik report-only mode om nieuwe policies te testen. Implementeer gradual rollout via user groups</li>
                        <li><strong>Zero Trust:</strong> Implementeer "never trust, always verify" - gebruik device compliance, location en risk-based policies</li>
                        <li><strong>DLP Policies:</strong> Start met sensitive info types (credit cards, SSN). Gebruik test mode voordat enforcement</li>
                        <li><strong>Retention Policies:</strong> Configureer org-wide retention voor Teams/Exchange/SharePoint (aanbevolen: 7 jaar voor legal hold)</li>
                        <li><strong>Legacy Authentication:</strong> Block legacy authentication protocols (IMAP, POP, SMTP) via CA policies</li>
                        <li><strong>App Registration Security:</strong> Monitor secrets expiration. Use certificates instead of secrets. Implement least privilege permissions</li>
                        <li><strong>Audit Monitoring:</strong> Configureer alerts voor suspicious activities (impossible travel, mass downloads, privilege escalation)</li>
                        <li><strong>Compliance Manager:</strong> Gebruik Microsoft Purview Compliance Manager voor compliance score en improvement actions</li>
                    </ul>
                </div>
            </div>
        </div>    
"@
    }    
    # PHASE 4 CONTENT - ADVANCED SECURITY & COMPLIANCE
    if (-not $SkipPhase4) {
        $html += @"
        <div id="phase4" class="phase-content">
            <h1>🛡️ Beveiliging</h1>
            
            <div class="section">
                <h2 class="section-title">🎯 Microsoft Secure Score</h2>
"@
        
        if ($global:Phase4Data.SecureScore) {
            $scorePercentage = $global:Phase4Data.SecureScore.Percentage
            $scoreColor = if ($scorePercentage -ge 75) { '#27ae60' } 
            elseif ($scorePercentage -ge 50) { '#f39c12' }
            else { '#ff6600' }
            
            $html += @"
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number" style="color: $scoreColor;">$scorePercentage%</div>
                        <div class="stat-label">Secure Score</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase4Data.SecureScore.CurrentScore)</div>
                        <div class="stat-label">Current Score</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase4Data.SecureScore.MaxScore)</div>
                        <div class="stat-label">Max Score</div>
                    </div>
                </div>
"@
            
            if ($global:Phase4Data.SecureScoreTopRecommendations -and $global:Phase4Data.SecureScoreTopRecommendations.Count -gt 0) {
                $html += "<h3>🔝 Top 5 Aanbevelingen</h3>"
                $html += "<div class='table-container'><table>"
                $html += "<thead><tr><th>Aanbeveling</th><th>Impact</th><th>Status</th></tr></thead><tbody>"
                foreach ($rec in $global:Phase4Data.SecureScoreTopRecommendations) {
                    $html += "<tr><td>$($rec.title)</td><td>$($rec.maxScore)</td><td>$($rec.implementationStatus)</td></tr>"
                }
                $html += "</tbody></table></div>"
            }
        }
        else {
            $html += "<p>Secure Score data niet beschikbaar</p>"
        }
        
        $html += @"
            </div>
            
            <div class="section">
                <h2 class="section-title">👤 Admin Password Ages</h2>
"@
        
        if ($global:Phase4Data.AdminPasswordAges -and $global:Phase4Data.AdminPasswordAges.Count -gt 0) {
            $html += @"
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase4Data.AdminPasswordAges.Count)</div>
                        <div class="stat-label">Admins</div>
                    </div>
                    <div class="stat-card" style="background: #F8D7DA;">
                        <div class="stat-number" style="color: #721c24;">$($global:Phase4Data.AdminsWithOldPasswords)</div>
                        <div class="stat-label" style="color: #721c24;">>180 dagen</div>
                    </div>
                </div>
                
                <h3>Admin Wachtwoord Details</h3>
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Display Name</th><th>UPN</th><th>Laatste Wijziging</th><th>Dagen Oud</th><th>Status</th></tr>
                    </thead>
                    <tbody>
"@
            foreach ($admin in $global:Phase4Data.AdminPasswordAges | Sort-Object -Property PasswordAgeDays -Descending) {
                $html += "<tr><td>$($admin.DisplayName)</td><td>$($admin.UserPrincipalName)</td><td>$($admin.LastPasswordChange)</td><td>$($admin.PasswordAgeDays)</td><td>$($admin.Status)</td></tr>"
            }
            $html += "</table></div>"
        }
        else {
            $html += "<p>Geen admin password data beschikbaar</p>"
        }
        
        $html += @"
            </div>
            
            <div class="section">
                <h2 class="section-title">🚨 Break Glass Accounts</h2>
"@
        
        if ($global:Phase4Data.BreakGlassAccounts -and $global:Phase4Data.BreakGlassAccounts.Count -gt 0) {
            $html += @"
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Display Name</th><th>UPN</th><th>Confidence</th><th>Redenen</th></tr>
                    </thead>
                    <tbody>
"@
            foreach ($bg in $global:Phase4Data.BreakGlassAccounts) {
                $html += "<tr><td>$($bg.DisplayName)</td><td>$($bg.UserPrincipalName)</td><td>$($bg.ConfidenceLevel)</td><td>$($bg.Reasons)</td></tr>"
            }
            $html += "</table></div>"
        }
        else {
            $html += "<p>Geen potentiële break glass accounts gedetecteerd</p>"
        }
        
        $html += @"
            </div>
            
            <div class="section">
                <h2 class="section-title">🤝 GDAP/GSAP Relationships</h2>
"@
        
        if ($global:Phase4Data.GDAPRelationships -and $global:Phase4Data.GDAPRelationships.Count -gt 0) {
            $html += @"
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Name</th><th>Status</th><th>Customer</th><th>Duration</th><th>Created</th></tr>
                    </thead>
                    <tbody>
"@
            foreach ($gdap in $global:Phase4Data.GDAPRelationships) {
                $html += "<tr><td>$($gdap.DisplayName)</td><td>$($gdap.Status)</td><td>$($gdap.Customer)</td><td>$($gdap.Duration)</td><td>$($gdap.CreatedDateTime)</td></tr>"
            }
            $html += "</table></div>"
        }
        else {
            $html += "<p>Geen GDAP/GSAP relationships gevonden ga naar: https://admin.microsoft.com/adminportal/home#/partners om deze informatie in te zien</p>"
        }
        
        $html += @"
            </div>
"@
            
        # Password Policies
        if ($global:Phase4Data.Domains -and (SafeCount $global:Phase4Data.Domains) -gt 0) {
            $html += @"
            <div class="section">
                <h2 class="section-title">🔑 Password Policies</h2>
                <h3>Domain Password Settings</h3>
                <div class="table-container">
                <table>
                    <thead><tr><th>Domain</th><th>Default</th><th>Password Validity (Days)</th><th>Notification Window (Days)</th></tr></thead>
                    <tbody>
"@
            foreach ($domain in $global:Phase4Data.Domains) {
                $isDefault = if ($domain.IsDefault) { "✓" } else { "" }
                $html += "<tr><td>$($domain.Id)</td><td>$isDefault</td><td>$($domain.PasswordValidityPeriodInDays)</td><td>$($domain.PasswordNotificationWindowInDays)</td></tr>"
            }
            $html += "</tbody></table></div></div>"
        }
        
        if ($global:Phase4Data.UsersWithNeverExpirePassword -and $global:Phase4Data.UsersWithNeverExpirePassword.Count -gt 0) {
            $html += @"
                <h3>⚠️ Users met Wachtwoord Nooit Verloopt ($($global:Phase4Data.UsersWithNeverExpirePassword.Count))</h3>
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Display Name</th><th>UPN</th></tr>
                    </thead>
                    <tbody>
"@
            foreach ($user in $global:Phase4Data.UsersWithNeverExpirePassword) {
                $html += "<tr><td>$($user.DisplayName)</td><td>$($user.UserPrincipalName)</td></tr>"
            }
            $html += "</table></div>"
        }
        
        $html += @"
               <h2 class="section-title">👥 Guest Invite Settings</h2>
"@
        
        if ($global:Phase4Data.GuestInviteSettings) {
            $html += @"
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Setting</th><th>Value</th></tr>
                    </thead>
                    <tbody>
                    <tr><td>Allow Invites From</td><td>$($global:Phase4Data.GuestInviteSettings.AllowInvitesFrom)</td></tr>
                    <tr><td>Email Subscriptions</td><td>$($global:Phase4Data.GuestInviteSettings.AllowedToSignUpEmailBasedSubscriptions)</td></tr>
                    <tr><td>Self-Service Password Reset</td><td>$($global:Phase4Data.GuestInviteSettings.AllowedToUseSSPR)</td></tr>
                    <tr><td>Email Verified Users Can Join</td><td>$($global:Phase4Data.GuestInviteSettings.AllowEmailVerifiedUsersToJoinOrganization)</td></tr>
                    <tr><td>Block MSOL PowerShell</td><td>$($global:Phase4Data.GuestInviteSettings.BlockMsolPowerShell)</td></tr>
                    </tbody>
                </table></div>
"@
        }
        else {
            $html += "<p>Guest invite settings niet beschikbaar</p>"
        }
        
        $html += @"
                <h2 class="section-title">📱 Device Registration Policy</h2>
"@
        
        if ($global:Phase4Data.DeviceRegistrationPolicy) {
            $html += @"
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Setting</th><th>Value</th></tr>
                    </thead>
                    <tbody>
                    <tr><td>User Device Quota</td><td>$($global:Phase4Data.DeviceRegistrationPolicy.UserDeviceQuota)</td></tr>
                    <tr><td>MFA Configuration</td><td>$($global:Phase4Data.DeviceRegistrationPolicy.MultiFactorAuthConfiguration)</td></tr>
                    <tr><td>Azure AD Join Allowed</td><td>$($global:Phase4Data.DeviceRegistrationPolicy.AzureADJoinAllowed)</td></tr>
                    <tr><td>Azure AD Registration Allowed</td><td>$($global:Phase4Data.DeviceRegistrationPolicy.AzureADRegistrationAllowed)</td></tr>
                    </tbody>
                </table></div>
"@
        }
        else {
            $html += "<p>Device registration policy niet beschikbaar</p>"
        }
        
        $html += @"
                <h2 class="section-title">🌍 Location-Based CA Policies</h2>
"@
        
        if ($global:Phase4Data.LocationBasedCAPolicies -and $global:Phase4Data.LocationBasedCAPolicies.Count -gt 0) {
            $html += @"
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Policy Name</th><th>State</th><th>Include Locations</th><th>Exclude Locations</th></tr>
                    </thead>
                    <tbody>
"@
            foreach ($policy in $global:Phase4Data.LocationBasedCAPolicies) {
                $html += "<tr><td>$($policy.PolicyName)</td><td>$($policy.State)</td><td>$($policy.IncludeLocations)</td><td>$($policy.ExcludeLocations)</td></tr>"
            }
            $html += "</table></div>"
        }
        else {
            $html += "<p>Geen location-based CA policies gevonden</p>"
        }
        
        $html += @"
                <h2 class="section-title">💻 Device-Based CA Policies</h2>
"@
        
        if ($global:Phase4Data.DeviceBasedCAPolicies -and $global:Phase4Data.DeviceBasedCAPolicies.Count -gt 0) {
            $html += @"
                <div class="table-container">
                <table>
                    <thead>
                    <tr><th>Policy Name</th><th>State</th><th>Device Requirements</th><th>Operator</th></tr>
                    </thead>
                    <tbody>
"@
            foreach ($policy in $global:Phase4Data.DeviceBasedCAPolicies) {
                $html += "<tr><td>$($policy.PolicyName)</td><td>$($policy.State)</td><td>$($policy.DeviceRequirements)</td><td>$($policy.Operator)</td></tr>"
            }
            $html += "</table></div>"
        }
        else {
            $html += "<p>Geen device-based CA policies gevonden</p>"
        }
        
        $html += @"
            <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
                <h2 class="section-title">💡 Aanbevelingen - Phase 4: Advanced Security & Compliance</h2>
                <p style="margin-bottom: 20px; color: #666;">Microsoft best practices voor advanced security, GDAP, password policies en device management:</p>
                
                <div style="margin-top: 15px;">
"@
        
        # Phase 4 Recommendations
        $phase4Recs = @()
        
        if ($global:Phase4Data.SecureScore -and $global:Phase4Data.SecureScore.Percentage -lt 50) {
            $phase4Recs += New-HtmlAlert -Type critical -Message "<strong>🎯 Secure Score Te Laag ($($global:Phase4Data.SecureScore.Percentage)%):</strong> <br><strong>Microsoft Best Practice:</strong> Target minimaal 70% Secure Score. Implementeer de top 5 recommendations die het meeste impact hebben. Focus eerst op identity protection, MFA enforcement en data protection."
        }
        elseif ($global:Phase4Data.SecureScore -and $global:Phase4Data.SecureScore.Percentage -lt 70) {
            $phase4Recs += New-HtmlAlert -Type warning -Message "<strong>🎯 Secure Score Verbetering Mogelijk ($($global:Phase4Data.SecureScore.Percentage)%):</strong> <br><strong>Microsoft Best Practice:</strong> Implementeer de aanbevolen security controls. Gebruik Microsoft Defender for Cloud Apps voor Cloud App Security."
        }
        
        if ($global:Phase4Data.AdminsWithOldPasswords -gt 0) {
            $phase4Recs += New-HtmlAlert -Type critical -Message "<strong>🔑 Admin Password Hygiene (Critical):</strong> $($global:Phase4Data.AdminsWithOldPasswords) admin(s) hebben wachtwoorden ouder dan 180 dagen. <br><strong>Microsoft Best Practice:</strong> Forceer password reset voor admins elke 90 dagen of gebruik passwordless authentication (FIDO2, Windows Hello for Business). Implementeer password rotation policy."
        }
        
        if ($global:Phase4Data.BreakGlassAccounts -and $global:Phase4Data.BreakGlassAccounts.Count -eq 0) {
            $phase4Recs += New-HtmlAlert -Type warning -Message "<strong>🚨 Break Glass Accounts:</strong> Geen break glass accounts gedetecteerd (heuristic). <br><strong>Microsoft Best Practice:</strong> Configureer minimaal 2 cloud-only emergency access accounts met Global Admin rechten. Exclude deze van CA policies en MFA. Monitor gebruik strikt. Gebruik strong passwords (>20 characters) en sla credentials op in fysieke kluis."
        }
        elseif ($global:Phase4Data.BreakGlassAccounts -and $global:Phase4Data.BreakGlassAccounts.Count -gt 0) {
            $phase4Recs += New-HtmlAlert -Type info -Message "<strong>🚨 Break Glass Accounts Gevonden ($($global:Phase4Data.BreakGlassAccounts.Count)):</strong> <br><strong>Microsoft Best Practice:</strong> Verify dat deze accounts: (1) Cloud-only zijn, (2) Excluded van MFA/CA policies, (3) Geen mail forwarding, (4) Credentials in secure vault, (5) Gebruik wordt gemonitord via alerts."
        }
        
        if ($global:Phase4Data.UsersWithNeverExpirePassword -and $global:Phase4Data.UsersWithNeverExpirePassword.Count -gt 5) {
            $phase4Recs += New-HtmlAlert -Type warning -Message "<strong>🔐 Password Expiration Policy:</strong> $($global:Phase4Data.UsersWithNeverExpirePassword.Count) gebruiker(s) hebben wachtwoorden die nooit verlopen. <br><strong>Microsoft Best Practice:</strong> Moderne aanpak: Disable password expiration maar enforce strong passwords + MFA + leaked password detection (Azure AD Password Protection). Voor compliance: 90-day rotation policy."
        }
        
        if ($global:Phase4Data.LocationBasedCAPolicies -and $global:Phase4Data.LocationBasedCAPolicies.Count -eq 0) {
            $phase4Recs += New-HtmlAlert -Type info -Message "<strong>🌍 Location-Based Access:</strong> Geen location-based CA policies gevonden. <br><strong>Microsoft Best Practice:</strong> Implementeer named locations voor trusted office IPs. Block access from high-risk countries. Use location as signal in risk-based CA policies."
        }
        
        if ($global:Phase4Data.DeviceBasedCAPolicies -and $global:Phase4Data.DeviceBasedCAPolicies.Count -eq 0) {
            $phase4Recs += New-HtmlAlert -Type warning -Message "<strong>💻 Device Compliance:</strong> Geen device-based CA policies gevonden. <br><strong>Microsoft Best Practice:</strong> Require compliant or hybrid joined devices voor toegang tot corporate resources. Implement device compliance policies via Intune voor minimale security baseline (encryption, antivirus, firewall)."
        }
        
        if ($phase4Recs.Count -eq 0) {
            $phase4Recs += New-HtmlAlert -Type success -Message "<strong>✅ Geen kritieke issues gevonden in Phase 4</strong>"
        }
        
        foreach ($rec in $phase4Recs) {
            $html += "                    $rec"
        }
        
        $html += @"
                
                <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
                    <h4 style="margin-top: 0;">📋 Algemene Best Practices - Phase 4</h4>
                    <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
                        <li><strong>Secure Score Monitoring:</strong> Review Secure Score monthly. Prioritize high-impact, low-effort improvements</li>
                        <li><strong>Privileged Access:</strong> Implement Privileged Identity Management (PIM) voor just-in-time admin access</li>
                        <li><strong>Password Protection:</strong> Enable Azure AD Password Protection (banned passwords, smart lockout)</li>
                        <li><strong>Break Glass Procedures:</strong> Document emergency access procedures. Test annually. Monitor via alerts</li>
                        <li><strong>GDAP Best Practices:</strong> Voor MSPs: Use GDAP instead of DAP. Implement least privilege. Regular access reviews</li>
                        <li><strong>Named Locations:</strong> Define trusted IPs. Use in CA policies voor location-aware access control</li>
                        <li><strong>Device Management:</strong> Enroll all corporate devices in Intune. Enforce compliance baseline</li>
                        <li><strong>Guest Access Governance:</strong> Implement quarterly access reviews. Use sensitivity labels voor classificatie</li>
                    </ul>
                </div>
            </div>
        </div>
"@
        
        $html += "        </div>"
    }
    
    # PHASE 5 CONTENT - INTUNE CONFIGURATION
    if (-not $SkipPhase5 -and $global:Phase5Data.IntuneAvailable) {
        $html += @"
        <div id="phase5" class="phase-content">
            <h1>📱 Intune</h1>
"@

        # Windows Autopilot Section
        if ($global:Phase5Data.AutopilotDeploymentProfiles -and (SafeCount $global:Phase5Data.AutopilotDeploymentProfiles) -gt 0) {
            $html += @"
            <div class="section">
                <h2 class="section-title">🚀 Windows Autopilot</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number">$(SafeCount $global:Phase5Data.AutopilotDeploymentProfiles)</div>
                        <div class="stat-label">Deployment Profiles</div>
                    </div>
                </div>
                <h3>Autopilot Deployment Profiles</h3>
"@
            $apData = $global:Phase5Data.AutopilotDeploymentProfiles | Select-Object DisplayName, @{N = 'Type'; E = { $_.'@odata.type' -replace '#microsoft.graph.', '' } }, DeviceNameTemplate, @{N = 'EnrollmentStatusPage'; E = { if ($_.enableEnrollmentStatusPage) { "Enabled" }else { "Disabled" } } }
            $html += New-HtmlTable -Data $apData -Properties @('DisplayName', 'Type', 'DeviceNameTemplate', 'EnrollmentStatusPage') -Headers @('Profile Name', 'Deployment Type', 'Name Template', 'ESP Status')
            $html += "</div>"
        }

        # Managed Devices Summary
        if ($global:Phase5Data.ManagedDevicesSummary) {
            $compliancePercentage = $global:Phase5Data.ManagedDevicesSummary.CompliancePercentage
            $complianceColor = if ($compliancePercentage -ge 90) { '#27ae60' } 
            elseif ($compliancePercentage -ge 70) { '#f39c12' }
            else { '#ff6600' }
            
            $html += @"
            <div class="section">
                <h2 class="section-title">📊 Managed Devices Summary</h2>
                <div class="stats-grid">
                    <div class="stat-card">
                        <div class="stat-number">$($global:Phase5Data.ManagedDevicesSummary.TotalDevices)</div>
                        <div class="stat-label">Total Devices</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" style="color: #27ae60;">$($global:Phase5Data.ManagedDevicesSummary.CompliantDevices)</div>
                        <div class="stat-label">Compliant</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" style="color: #ff6600;">$($global:Phase5Data.ManagedDevicesSummary.NonCompliantDevices)</div>
                        <div class="stat-label">Non-Compliant</div>
                    </div>
                    <div class="stat-card">
                        <div class="stat-number" style="color: $complianceColor;">$compliancePercentage%</div>
                        <div class="stat-label">Compliance Rate</div>
                    </div>
                </div>
"@
            
            if ($global:Phase5Data.DevicesByOS -and (SafeCount $global:Phase5Data.DevicesByOS) -gt 0) {
                $html += "<h3>Devices per OS</h3>"
                $html += New-HtmlTable -Data $global:Phase5Data.DevicesByOS -Properties @('Name', 'Count') -Headers @('Operating System', 'Count')
            }
            $html += "</div>"
        }
        
        # Compliance Policies
        if ($global:Phase5Data.CompliancePolicies -and (SafeCount $global:Phase5Data.CompliancePolicies) -gt 0) {
            $html += @"
            <div class="section">
                <h2 class="section-title">✅ Compliance Policies</h2>
"@
            $html += New-HtmlTable -Data $global:Phase5Data.CompliancePolicies -Properties @('DisplayName', 'Platform', 'CreatedDateTime', 'LastModifiedDateTime') -Headers @('Name', 'Platform', 'Created', 'Last Modified')
            $html += "</div>"
        }
        else {
            $html += @"
            <div class="section">
                <h2 class="section-title">✅ Compliance Policies</h2>
                <p>Geen compliance policies gevonden</p>
            </div>
"@
        }
        
        # Configuration Profiles
        if ($global:Phase5Data.ConfigurationProfiles -and (SafeCount $global:Phase5Data.ConfigurationProfiles) -gt 0) {
            $html += @"
            <div class="section">
                <h2 class="section-title">⚙️ Configuration Profiles</h2>
"@
            $html += New-HtmlTable -Data $global:Phase5Data.ConfigurationProfiles -Properties @('DisplayName', 'Platform', 'CreatedDateTime', 'LastModifiedDateTime') -Headers @('Name', 'Platform', 'Created', 'Last Modified')
            $html += "</div>"
        }
        else {
            $html += @"
            <div class="section">
                <h2 class="section-title">⚙️ Configuration Profiles</h2>
                <p>Geen configuration profiles gevonden</p>
            </div>
"@
        }
        
        # Endpoint Security Policies
        if ($global:Phase5Data.EndpointSecurityPolicies -and (SafeCount $global:Phase5Data.EndpointSecurityPolicies) -gt 0) {
            $html += @"
            <div class="section">
                <h2 class="section-title">🛡️ Endpoint Security Policies</h2>
"@
            $html += New-HtmlTable -Data $global:Phase5Data.EndpointSecurityPolicies -Properties @('DisplayName', 'Type', 'LastModifiedDateTime') -Headers @('Name', 'Type', 'Last Modified')
            $html += "</div>"
        }
        else {
            $html += @"
            <div class="section">
                <h2 class="section-title">🛡️ Endpoint Security Policies</h2>
                <p>Geen endpoint security policies gevonden</p>
            </div>
"@
        }
        
        # App Protection Policies (MAM)
        if ($global:Phase5Data.AppProtectionPolicies -and (SafeCount $global:Phase5Data.AppProtectionPolicies) -gt 0) {
            $html += @"
            <div class="section">
                <h2 class="section-title">📲 App Protection Policies (MAM)</h2>
"@
            $html += New-HtmlTable -Data $global:Phase5Data.AppProtectionPolicies -Properties @('DisplayName', 'Platform', 'CreatedDateTime', 'LastModifiedDateTime') -Headers @('Name', 'Platform', 'Created', 'Last Modified')
            $html += "</div>"
        }
        else {
            $html += @"
            <div class="section">
                <h2 class="section-title">📲 App Protection Policies (MAM)</h2>
                <p>Geen app protection policies gevonden</p>
            </div>
"@
        }
        
        # Recommendations Phase 5
        $html += @"
            <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
                <h2 class="section-title">💡 Aanbevelingen - Phase 5: Intune Configuration</h2>
                <p style="margin-bottom: 20px; color: #666;">Microsoft best practices voor Intune device management, compliance en app protection:</p>
                
                <div style="margin-top: 15px;">
"@
        
        $phase5Recs = @()
        
        if ($global:Phase5Data.ManagedDevicesSummary -and $global:Phase5Data.ManagedDevicesSummary.CompliancePercentage -lt 90) {
            $phase5Recs += New-HtmlAlert -Type warning -Message "<strong>📱 Device Compliance Te Laag ($($global:Phase5Data.ManagedDevicesSummary.CompliancePercentage)%):</strong> Slechts $($global:Phase5Data.ManagedDevicesSummary.CompliantDevices) van $($global:Phase5Data.ManagedDevicesSummary.TotalDevices) devices zijn compliant. <br><strong>Microsoft Best Practice:</strong> Target minimaal 95% compliance. Review non-compliant devices wekelijks. Gebruik Conditional Access om non-compliant devices te blokkeren van corporate resources."
        }
        elseif ($global:Phase5Data.ManagedDevicesSummary -and $global:Phase5Data.ManagedDevicesSummary.CompliancePercentage -ge 90) {
            $phase5Recs += New-HtmlAlert -Type success -Message "<strong>✅ Goede Device Compliance ($($global:Phase5Data.ManagedDevicesSummary.CompliancePercentage)%):</strong> Device compliance is goed. Continue monitoring en enforcement via CA policies."
        }
        
        if ((-not $global:Phase5Data.CompliancePolicies -or $global:Phase5Data.CompliancePolicies.Count -eq 0) -and $global:Phase5Data.ManagedDevicesSummary.TotalDevices -gt 0) {
            $phase5Recs += New-HtmlAlert -Type critical -Message "<strong>⚠️ Geen Compliance Policies (Critical):</strong> Er zijn $($global:Phase5Data.ManagedDevicesSummary.TotalDevices) managed devices maar geen compliance policies. <br><strong>Microsoft Best Practice:</strong> Implementeer compliance policies per platform (iOS, Android, Windows). Minimale baseline: BitLocker/encryption, firewall enabled, antivirus up-to-date, OS version requirements."
        }
        
        if ((-not $global:Phase5Data.ConfigurationProfiles -or $global:Phase5Data.ConfigurationProfiles.Count -lt 3) -and $global:Phase5Data.ManagedDevicesSummary.TotalDevices -gt 10) {
            $phase5Recs += New-HtmlAlert -Type warning -Message "<strong>⚙️ Configuration Profiles:</strong> Weinig configuration profiles gevonden ($($global:Phase5Data.ConfigurationProfiles.Count)). <br><strong>Microsoft Best Practice:</strong> Implementeer configuration profiles voor: WiFi, VPN, email, certificates, device restrictions. Gebruik policy sets voor consistent deployment."
        }
        
        if ((-not $global:Phase5Data.EndpointSecurityPolicies -or $global:Phase5Data.EndpointSecurityPolicies.Count -eq 0) -and $global:Phase5Data.ManagedDevicesSummary.TotalDevices -gt 0) {
            $phase5Recs += New-HtmlAlert -Type warning -Message "<strong>🛡️ Endpoint Security:</strong> Geen endpoint security policies gevonden. <br><strong>Microsoft Best Practice:</strong> Implementeer: (1) Antivirus policy (Microsoft Defender), (2) Firewall rules, (3) Attack Surface Reduction (ASR) rules, (4) Disk encryption (BitLocker). Gebruik security baselines als startpunt."
        }
        
        if ((-not $global:Phase5Data.AppProtectionPolicies -or $global:Phase5Data.AppProtectionPolicies.Count -eq 0)) {
            $phase5Recs += New-HtmlAlert -Type info -Message "<strong>📲 App Protection Policies (MAM):</strong> Geen app protection policies gevonden. <br><strong>Microsoft Best Practice:</strong> Implementeer MAM policies voor iOS/Android voor BYOD scenarios. Bescherm corporate data in mobile apps (Outlook, OneDrive, Teams) zonder device enrollment. Require app PIN, block screen capture, restrict copy/paste."
        }
        
        if ((SafeCount $phase5Recs) -eq 0) {
            $phase5Recs += New-HtmlAlert -Type success -Message "<strong>✅ Geen kritieke issues gevonden in Phase 5</strong>"
        }
        
        foreach ($rec in $phase5Recs) {
            $html += "                    $rec"
        }
        
        $html += @"
                </div>
                
                <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
                    <h4 style="margin-top: 0;">📋 Algemene Best Practices - Phase 5 (Intune)</h4>
                    <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
                        <li><strong>Enrollment Methods:</strong> Use Windows Autopilot voor Windows devices. Apple Device Enrollment Program (DEP) voor iOS/macOS</li>
                        <li><strong>Compliance Policies:</strong> Create platform-specific compliance policies. Use grace period (3-7 days) before marking non-compliant</li>
                        <li><strong>Security Baselines:</strong> Deploy security baselines voor Windows 10/11, Microsoft Edge, Microsoft Defender</li>
                        <li><strong>Conditional Access Integration:</strong> Require compliant or hybrid joined device via CA policies</li>
                        <li><strong>Update Rings:</strong> Use Windows Update for Business. Stagger deployments (pilot → broad → production)</li>
                        <li><strong>App Deployment:</strong> Use Microsoft Store for Business. Deploy LOB apps via Intune. Use required/available assignments</li>
                        <li><strong>Remote Actions:</strong> Enable remote wipe, retire, lock. Document procedures voor lost/stolen devices</li>
                        <li><strong>Monitoring:</strong> Use Endpoint Analytics voor insights. Monitor compliance trends monthly. Use proactive remediations</li>
                        <li><strong>BYOD vs Corporate:</strong> Use MAM policies voor BYOD. Full MDM enrollment voor corporate-owned devices</li>
                    </ul>
                </div>
            </div>
        </div>
"@
    }
    elseif (-not $SkipPhase5) {
        $html += @"
        <div id="phase5" class="phase-content">
            <h1>📱 Intune</h1>
            <div class="section">
                <p style="color: #666; font-style: italic;">Intune is niet geconfigureerd of niet toegankelijk voor deze tenant.</p>
            </div>
            
            <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
                <h2 class="section-title">💡 Aanbevelingen - Phase 5: Intune Configuration</h2>
                <p style="margin-bottom: 20px; color: #666;">Intune is momenteel niet geconfigureerd. Overweeg Intune te activeren voor device management.</p>
                
                <div style="margin-top: 15px;">
"@
        $html += New-HtmlAlert -Type info -Message "<strong>📱 Intune Niet Actief:</strong> <br><strong>Microsoft Best Practice:</strong> Overweeg Microsoft Intune voor: (1) Mobile Device Management (MDM), (2) Mobile Application Management (MAM), (3) Device compliance policies, (4) App protection. Vereist minimaal Microsoft 365 Business Premium of Enterprise Mobility + Security E3 licentie."
        $html += @"
                </div>
                
                <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
                    <h4 style="margin-top: 0;">📋 Intune Benefits</h4>
                    <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
                        <li><strong>Device Management:</strong> Centraal beheer van Windows, iOS, Android, macOS devices</li>
                        <li><strong>Security Enforcement:</strong> Device compliance policies, encryption requirements, security baselines</li>
                        <li><strong>App Management:</strong> Deploy en manage corporate apps. App protection voor BYOD</li>
                        <li><strong>Conditional Access:</strong> Enforce device compliance voor toegang tot corporate resources</li>
                        <li><strong>Remote Actions:</strong> Wipe, retire, lock lost/stolen devices remotely</li>
                    </ul>
                </div>
            </div>
        </div>
"@
    }
    
    # ============================================================================
    # PHASE 6: AZURE INFRASTRUCTURE BEST PRACTICES
    # ============================================================================

    # If Phase6 data exists but there are no subscriptions, show Intune-style message
    if (-not $SkipPhase6 -and $global:Phase6Data -and ($global:Phase6Data.SubscriptionCount -eq 0 -or -not $global:Phase6Data.SubscriptionCount)) {
        $html += @"
        <div id="phase6" class="phase-content">
            <h1>☁️ Azure</h1>
        <div class="section">
        <p style="color: #666; font-style: italic;">Azure is niet geconfigureerd of niet toegankelijk voor deze tenant.</p>
        </div>
            
        <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
                <h2 class="section-title">💡 Aanbevelingen - Phase 6: Azure Infrastructure</h2>
        <p style="margin-bottom: 20px; color: #666;">Azure is momenteel niet geconfigureerd. Overweeg Azure te activeren en een subscription toe te voegen voor infrastructure assessments.</p>
                
        <div style="margin-top: 15px;">
"@

        $html += New-HtmlAlert -Type info -Message "<strong>☁️ Azure Niet Actief:</strong> <br><strong>Microsoft Best Practice:</strong> Zorg dat minstens één Azure subscription aanwezig is en dat een service account met minimale leesrechten (Reader / Security Reader) beschikbaar is voor assessment scripts. Activeer Azure Monitor en Log Analytics voor observability."

        $html += @"
        </div>

        <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
        <h4 style="margin-top: 0;">📋 Aanbevolen stappen en voordelen - Azure</h4>
        <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
        <li><strong>Subscriptions & RBAC:</strong> Zorg voor duidelijke subscription structuur en gebruik management groups. Geef assessment account de Reader of Security Reader rol (least privilege).</li>
        <li><strong>Governance (Policy & Tags):</strong> Implementeer Azure Policy en tagging strategy (Owner, CostCenter, Environment) voor kosten en compliance.</li>
        <li><strong>Network Security:</strong> Gebruik NSGs, Azure Firewall en Private Endpoints; beperk public exposure en voorkom permissieve NSG rules.</li>
        <li><strong>Security & Monitoring:</strong> Activeer Microsoft Defender for Cloud, Azure Security Center en configureer Log Analytics + diagnostic settings.</li>
        <li><strong>Backup & DR:</strong> Schakel Azure Backup/Recovery Services in voor kritieke resources en test restore procedures.</li>
        <li><strong>Storage Security:</strong> Disable public blob access waar mogelijk, enforce HTTPS-only en gebruik encryption met customer-managed keys indien nodig.</li>
        <li><strong>Cost Management:</strong> Configureer budgets, alerts en reserved instances waar passend voor kostenoptimalisatie.</li>
        <li><strong>Operational Best Practices:</strong> Automate tagging, enable resource locks voor productie en document governance processen.</li>
        </ul>
        </div>
        </div>
"@

        $html += "        </div>"
    }
    elseif (-not $SkipPhase6 -and $global:Phase6Data.AzureAvailable) {
        $html += @"
        <div id="phase6" class="phase-content">
            <h1>☁️ Azure</h1>
            
        <div class="section">
        <h2 class="section-title">📊 Azure Subscription Overview</h2>
        <p><strong>Subscription:</strong> $($global:Phase6Data.SubscriptionName)</p>
        <p><strong>Subscription ID:</strong> $($global:Phase6Data.SubscriptionId)</p>
        </div>
"@
        
        # 1. Azure Virtual Desktop
        if ($global:Phase6Data.AVD -and $global:Phase6Data.AVD.TotalHostPools -gt 0) {
            $html += @"
        <div class="section">
        <h2 class="section-title">🖥️ Azure Virtual Desktop (AVD)</h2>
"@
            $avdCards = @(
                @{Number = $global:Phase6Data.AVD.TotalHostPools; Label = 'Host Pools' },
                @{Number = $global:Phase6Data.AVD.TotalSessionHosts; Label = 'Session Hosts' },
                @{Number = $global:Phase6Data.AVD.Issues.Count; Label = 'Issues Found' }
            )
            $html += New-HtmlStatsGrid -Cards $avdCards
            
            if ($global:Phase6Data.AVD.HostPools.Count -gt 0) {
                $avdData = $global:Phase6Data.AVD.HostPools | ForEach-Object {
                    [PSCustomObject]@{
                        Name          = $_.Name
                        ResourceGroup = $_.ResourceGroup
                        Type          = $_.HostPoolType
                        LoadBalancer  = $_.LoadBalancerType
                        MaxSessions   = $_.MaxSessionLimit
                        SessionHosts  = $_.SessionHosts
                        Validation    = if ($_.ValidationEnvironment) { "✓" } else { "✗" }
                        Issues        = $_.Issues.Count
                    }
                }
                $html += "<h3>Host Pools</h3>"
                $html += New-HtmlTable -Data $avdData -Properties @('Name', 'ResourceGroup', 'Type', 'LoadBalancer', 'MaxSessions', 'SessionHosts', 'Validation', 'Issues') -Headers @('Name', 'Resource Group', 'Type', 'Load Balancer', 'Max Sessions', 'Hosts', 'Validation Env', 'Issues')
            }
            
            if ($global:Phase6Data.AVD.Issues.Count -gt 0) {
                $html += New-HtmlAlert -Type warning -Message "<strong>⚠️ AVD Issues:</strong><br>$(($global:Phase6Data.AVD.Issues | Select-Object -Unique) -join '<br>')"
            }
            
            $html += "</div>"
        }
        
        # 2. Azure Compute
        if ($global:Phase6Data.Compute -and $global:Phase6Data.Compute.TotalVMs -gt 0) {
            $html += @"
        <div class="section">
        <h2 class="section-title">💻 Azure Compute (Virtual Machines)</h2>
"@
            $computeCards = @(
                @{Number = $global:Phase6Data.Compute.TotalVMs; Label = 'Total VMs' },
                @{Number = $global:Phase6Data.Compute.RunningVMs; Label = 'Running' },
                @{Number = $global:Phase6Data.Compute.StoppedVMs; Label = 'Stopped' },
                @{Number = $global:Phase6Data.Compute.Issues.Count; Label = 'Issues Found' }
            )
            $html += New-HtmlStatsGrid -Cards $computeCards
            
            if ($global:Phase6Data.Compute.VMs.Count -gt 0) {
                $vmData = $global:Phase6Data.Compute.VMs | Select-Object -First 20 | ForEach-Object {
                    [PSCustomObject]@{
                        Name             = $_.Name
                        Size             = $_.Size
                        Status           = $_.Status
                        OsType           = $_.OsType
                        ManagedDisks     = if ($_.ManagedDisks) { "✓" } else { "✗" }
                        AvailabilityZone = if ($_.AvailabilityZone) { $_.AvailabilityZone } else { "None" }
                        Issues           = $_.Issues.Count
                    }
                }
                $html += "<h3>Virtual Machines (Top 20)</h3>"
                $html += New-HtmlTable -Data $vmData -Properties @('Name', 'Size', 'Status', 'OsType', 'ManagedDisks', 'AvailabilityZone', 'Issues') -Headers @('Name', 'VM Size', 'Status', 'OS', 'Managed Disks', 'Availability Zone', 'Issues')
            }
            
            if ($global:Phase6Data.Compute.Issues.Count -gt 0) {
                $uniqueIssues = $global:Phase6Data.Compute.Issues | Select-Object -Unique | Select-Object -First 10
                $html += New-HtmlAlert -Type warning -Message "<strong>⚠️ Compute Issues (Top 10):</strong><br>$($uniqueIssues -join '<br>')"
            }
            
            $html += "</div>"
        }
        
        # 3. Azure Networking
        if ($global:Phase6Data.Networking -and $global:Phase6Data.Networking.TotalNSGs -gt 0) {
            $html += @"
        <div class="section">
        <h2 class="section-title">🌐 Azure Networking (Network Security Groups)</h2>
"@
            $netCards = @(
                @{Number = $global:Phase6Data.Networking.TotalNSGs; Label = 'NSGs' },
                @{Number = $global:Phase6Data.Networking.PermissiveRules; Label = 'Permissive Rules' }
            )
            $html += New-HtmlStatsGrid -Cards $netCards
            
            if ($global:Phase6Data.Networking.NSGs.Count -gt 0) {
                $nsgData = $global:Phase6Data.Networking.NSGs | ForEach-Object {
                    [PSCustomObject]@{
                        Name            = $_.Name
                        ResourceGroup   = $_.ResourceGroup
                        Location        = $_.Location
                        TotalRules      = $_.TotalRules
                        PermissiveRules = $_.PermissiveRules
                        Status          = if ($_.PermissiveRules -gt 0) { "⚠️ Review Needed" } else { "✓ Good" }
                    }
                }
                $html += "<h3>Network Security Groups</h3>"
                $html += New-HtmlTable -Data $nsgData -Properties @('Name', 'ResourceGroup', 'Location', 'TotalRules', 'PermissiveRules', 'Status') -Headers @('NSG Name', 'Resource Group', 'Location', 'Total Rules', 'Permissive Rules', 'Status')
            }
            
            if ($global:Phase6Data.Networking.PermissiveRules -gt 0) {
                $html += New-HtmlAlert -Type critical -Message "<strong>🔴 Security Risk:</strong> Found $($global:Phase6Data.Networking.PermissiveRules) permissive NSG rules allowing traffic from Internet. Review and restrict access."
            }
            
            $html += "</div>"
        }
        
        # 4. Azure Storage
        if ($global:Phase6Data.Storage -and $global:Phase6Data.Storage.TotalAccounts -gt 0) {
            $html += @"
        <div class="section">
        <h2 class="section-title">💾 Azure Storage Accounts</h2>
"@
            $storageCards = @(
                @{Number = $global:Phase6Data.Storage.TotalAccounts; Label = 'Storage Accounts' },
                @{Number = $global:Phase6Data.Storage.PublicAccessEnabled; Label = 'Public Access Enabled' },
                @{Number = $global:Phase6Data.Storage.Issues.Count; Label = 'Issues Found' }
            )
            $html += New-HtmlStatsGrid -Cards $storageCards
            
            if ($global:Phase6Data.Storage.Accounts.Count -gt 0) {
                $storageData = $global:Phase6Data.Storage.Accounts | ForEach-Object {
                    [PSCustomObject]@{
                        Name         = $_.Name
                        SKU          = $_.SKU
                        Location     = $_.Location
                        PublicAccess = if ($_.PublicAccess) { "❌ Enabled" } else { "✓ Disabled" }
                        HttpsOnly    = if ($_.HttpsOnly) { "✓" } else { "❌" }
                        Encryption   = if ($_.BlobEncryption) { "✓" } else { "❌" }
                        Issues       = $_.Issues.Count
                    }
                }
                $html += "<h3>Storage Accounts</h3>"
                $html += New-HtmlTable -Data $storageData -Properties @('Name', 'SKU', 'Location', 'PublicAccess', 'HttpsOnly', 'Encryption', 'Issues') -Headers @('Storage Account', 'SKU', 'Location', 'Public Access', 'HTTPS Only', 'Blob Encryption', 'Issues')
            }
            
            if ($global:Phase6Data.Storage.PublicAccessEnabled -gt 0) {
                $html += New-HtmlAlert -Type warning -Message "<strong>⚠️ Storage Security:</strong> $($global:Phase6Data.Storage.PublicAccessEnabled) storage account(s) have public blob access enabled. Disable unless specifically required."
            }
            
            $html += "</div>"
        }
        
        # 5. Azure Security
        if ($global:Phase6Data.Security) {
            $html += @"
        <div class="section">
        <h2 class="section-title">🛡️ Azure Security & Compliance</h2>
"@
            
            if ($global:Phase6Data.Security.DefenderPlans -and $global:Phase6Data.Security.DefenderPlans.Count -gt 0) {
                $html += "<h3>Microsoft Defender for Cloud Plans</h3>"
                $defenderData = $global:Phase6Data.Security.DefenderPlans | ForEach-Object {
                    [PSCustomObject]@{
                        Plan   = $_.Name
                        Tier   = $_.Tier
                        Status = if ($_.Tier -eq 'Standard') { "✓ Enabled" } else { "⚠️ Free Tier" }
                    }
                }
                $html += New-HtmlTable -Data $defenderData -Properties @('Plan', 'Tier', 'Status') -Headers @('Defender Plan', 'Pricing Tier', 'Status')
            }
            
            if ($global:Phase6Data.Security.Policies -and $global:Phase6Data.Security.Policies.Count -gt 0) {
                $html += "<h3>Azure Policy Assignments (Top 10)</h3>"
                $policyData = $global:Phase6Data.Security.Policies | ForEach-Object {
                    [PSCustomObject]@{
                        Name            = $_.DisplayName
                        EnforcementMode = $_.EnforcementMode
                    }
                }
                $html += New-HtmlTable -Data $policyData -Properties @('Name', 'EnforcementMode') -Headers @('Policy Name', 'Enforcement Mode')
            }
            
            $html += "</div>"
        }
        
        # 6. Governance & Compliance
        if ($global:Phase6Data.Governance -and $global:Phase6Data.Governance.TotalResourceGroups -gt 0) {
            $html += @"
        <div class="section">
        <h2 class="section-title">📋 Governance & Compliance</h2>
"@
            $govCards = @(
                @{Number = $global:Phase6Data.Governance.TotalResourceGroups; Label = 'Resource Groups' },
                @{Number = $global:Phase6Data.Governance.UntaggedResourceGroups; Label = 'Untagged' },
                @{Number = $global:Phase6Data.Governance.LockedResourceGroups; Label = 'With Locks' }
            )
            $html += New-HtmlStatsGrid -Cards $govCards
            
            if ($global:Phase6Data.Governance.ResourceGroups.Count -gt 0) {
                $rgData = $global:Phase6Data.Governance.ResourceGroups | Select-Object -First 20 | ForEach-Object {
                    [PSCustomObject]@{
                        Name     = $_.Name
                        Location = $_.Location
                        Tags     = $_.Tags
                        Locks    = $_.Locks
                        Status   = if ($_.Tags -gt 0 -and $_.Locks -gt 0) { "✓ Good" } else { "⚠️ Review" }
                    }
                }
                $html += "<h3>Resource Groups (Top 20)</h3>"
                $html += New-HtmlTable -Data $rgData -Properties @('Name', 'Location', 'Tags', 'Locks', 'Status') -Headers @('Resource Group', 'Location', 'Tags', 'Locks', 'Status')
            }
            
            if ($global:Phase6Data.Governance.UntaggedResourceGroups -gt 0) {
                $html += New-HtmlAlert -Type info -Message "<strong>ℹ️ Tagging Strategy:</strong> $($global:Phase6Data.Governance.UntaggedResourceGroups) resource group(s) have no tags. Implement tagging for cost tracking and governance."
            }
            
            $html += "</div>"
        }
        
        # PHASE 6 RECOMMENDATIONS
        $html += @"
        <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
                    <h2 class="section-title">💡 Aanbevelingen - Phase 6: Azure Infrastructure</h2>
            <div style="margin-top: 15px;">
"@
        $html += New-HtmlAlert -Type info -Message "<strong>☁️ Azure Assessment Voltooid:</strong> <br><strong>Microsoft Best Practice:</strong> Zorg dat subscriptions worden gemonitord via Microsoft Defender for Cloud en dat RBAC least-privilege (Reader/Security Reader) wordt toegepast voor auditing."
        $html += @"
            </div>
            <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
                <h4 style="margin-top: 0;">📋 Azure Best Practices</h4>
                <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
                    <li><strong>RBAC:</strong> Gebruik Reader rol voor rapportage en auditing.</li>
                    <li><strong>Governance:</strong> Implementeer Azure Policy voor resource compliance.</li>
                    <li><strong>Security:</strong> Schakel Defender for Cloud in voor alle subscriptions.</li>
                </ul>
            </div>
        </div>
"@
        
        $html += "        </div>"
    }
    elseif (-not $SkipPhase6) {
        $html += @"
        <div id="phase6" class="phase-content">
            <h1>☁️ Azure</h1>
        <div class="section">
        <p style="color: #666; font-style: italic;">Azure subscriptions of toegang zijn niet geconfigureerd of niet toegankelijk voor deze tenant.</p>
        </div>
            
        <div class="section" style="background: #f8f9fa; border-left: 4px solid #0066b3; padding: 20px; margin-top: 30px;">
                <h2 class="section-title">💡 Aanbevelingen - Phase 6: Azure Infrastructure</h2>
        <p style="margin-bottom: 20px; color: #666;">Azure assessment kon niet worden uitgevoerd. Overweeg de volgende stappen en Microsoft best practices om Azure governance, security en availability op te zetten.</p>
        <div style="margin-top: 15px;">
"@

        $html += New-HtmlAlert -Type info -Message "<strong>☁️ Azure Niet Beschikbaar:</strong> <br><strong>Microsoft Best Practice:</strong> Zorg dat minstens één Azure subscription aanwezig is en dat een service account met minimale leesrechten (Reader / Security Reader) beschikbaar is voor assessment scripts. Activeer Azure Monitor, Log Analytics en Microsoft Defender for Cloud voor security en observability."

        $html += @"
        </div>

        <div style="margin-top: 25px; padding: 15px; background: white; border-radius: 4px; border: 1px solid #dee2e6;">
        <h4 style="margin-top: 0;">📋 Aanbevolen stappen en voordelen - Azure</h4>
        <ul style="margin: 10px 0 0 20px; color: #555; line-height: 1.8;">
        <li><strong>Subscriptions & RBAC:</strong> Zorg voor duidelijke subscription structuur en gebruik management groups. Geef assessment account de Reader of Security Reader rol (least privilege).</li>
        <li><strong>Governance (Policy & Tags):</strong> Implementeer Azure Policy en tagging strategy (Owner, CostCenter, Environment) voor kosten en compliance.</li>
        <li><strong>Network Security:</strong> Gebruik NSGs, Azure Firewall en Private Endpoints; beperk public exposure en voorkom permissieve NSG rules.</li>
        <li><strong>Security & Monitoring:</strong> Activeer Microsoft Defender for Cloud, Azure Security Center en configureer Log Analytics + diagnostic settings.</li>
        <li><strong>Backup & DR:</strong> Schakel Azure Backup/Recovery Services in voor kritieke resources en test restore procedures.</li>
        <li><strong>Storage Security:</strong> Disable public blob access waar mogelijk, enforce HTTPS-only en gebruik encryption met customer-managed keys indien nodig.</li>
        <li><strong>Cost Management:</strong> Configureer budgets, alerts en reserved instances waar passend voor kostenoptimalisatie.</li>
        <li><strong>Operational Best Practices:</strong> Automate tagging, enable resource locks voor productie en document governance processen.</li>
        </ul>
        </div>
        </div>
"@

        $html += "        </div>"
    }
    
    # Footer
    $html += @"
        </div>
    
        <div class="footer">
        <p>Report generated by <strong>Denjoy - IT</strong> M365 Baseline Assessment Tool v$($global:Version)</p>
        <p>© 2025 Denjoy - IT | Assessment ID: $global:AssessmentId | <a href="https://www.denjoy.nl" style="color: #0066b3; text-decoration: none;">www.denjoy.nl</a></p>
        </div>

        <script>
        // Defined toggle function as a global for the onclick handlers
        window.togglePhase = function(phaseId) {
            var phase = document.getElementById(phaseId);
            if (!phase) return;
            var btn = phase.querySelector('.phase-toggle');
            if (btn) btn.click();
        };

        // Collapsible sections: wrap all content after phase-header into phase-body
        document.addEventListener('DOMContentLoaded', function () {
                document.querySelectorAll('.phase-content').forEach(function (phase) {
                        var header = phase.querySelector('h1');
                        if (!header) return;
                        
                        // Create a wrapper for the body if not already there
                        var body = phase.querySelector('.phase-body');
                        if (!body) {
                            body = document.createElement('div');
                            body.className = 'phase-body';
                            // Move all siblings AFTER header into body
                            var node = header.nextElementSibling;
                            while (node) {
                                if (node.classList.contains('phase-content')) break;
                                var next = node.nextElementSibling;
                                body.appendChild(node);
                                node = next;
                            }
                            phase.appendChild(body);
                        }

                        // Add toggle button to header if not already there
                        if (!header.querySelector('.phase-toggle')) {
                            var btn = document.createElement('button');
                            btn.className = 'phase-toggle open';
                            btn.innerHTML = '<span class="btn-label">Verberg detail</span> <span class="chev">▲</span>';
                            
                            btn.onclick = function(e) {
                                e.stopPropagation();
                                if (body.classList.contains('collapsed')) {
                                    body.classList.remove('collapsed');
                                    btn.classList.add('open');
                                    btn.innerHTML = '<span class="btn-label">Verberg detail</span> <span class="chev">▲</span>';
                                } else {
                                    body.classList.add('collapsed');
                                    btn.classList.remove('open');
                                    btn.innerHTML = '<span class="btn-label">Bekijk detail</span> <span class="chev">▼</span>';
                                }
                            };
                            
                            header.style.cursor = 'pointer';
                            header.onclick = function() { btn.click(); };
                            header.appendChild(btn);
                        }
                    });
            });
        </script>
        </body>
        </html>
"@

    # Save report
    if (-not (Test-Path $OutputPath)) {
        New-Item -Path $OutputPath -ItemType Directory -Force | Out-Null
    }
    
    $html | Out-File -FilePath $global:ReportFullPath -Encoding UTF8
    Write-AssessmentLog "✓ Report saved: $global:ReportFullPath" -Level Success
    
    # Create/update "latest" symlink or copy for easy access
    $latestPath = Join-Path $OutputPath "M365-Complete-Baseline-latest.html"
    try {
        # Try to create a symlink (works on Windows 10+, macOS, Linux)
        if (Test-Path $latestPath) {
            Remove-Item $latestPath -Force -ErrorAction SilentlyContinue
        }
        
        # Check if we can create symbolic links
        if ($IsWindows -and ([System.Environment]::OSVersion.Version.Major -ge 10)) {
            # Windows 10+ with developer mode or admin rights
            New-Item -ItemType SymbolicLink -Path $latestPath -Target $global:ReportFullPath -Force -ErrorAction Stop | Out-Null
            Write-AssessmentLog "✓ Symlink created: $latestPath -> $global:ReportFileName" -Level Success
        } elseif ($IsMacOS -or $IsLinux) {
            # Unix-like systems
            New-Item -ItemType SymbolicLink -Path $latestPath -Target $global:ReportFullPath -Force -ErrorAction Stop | Out-Null
            Write-AssessmentLog "✓ Symlink created: $latestPath -> $global:ReportFileName" -Level Success
        } else {
            # Fallback: create a copy instead of symlink
            Copy-Item -Path $global:ReportFullPath -Destination $latestPath -Force -ErrorAction Stop
            Write-AssessmentLog "✓ Latest report copied to: $latestPath" -Level Success
        }
    } catch {
        # If symlink fails, fall back to copy
        try {
            Copy-Item -Path $global:ReportFullPath -Destination $latestPath -Force -ErrorAction Stop
            Write-AssessmentLog "✓ Latest report copied to: $latestPath" -Level Success
        } catch {
            Write-AssessmentLog "! Warning: Could not create latest report reference: $_" -Level Warning
        }
    }
}

Export-ModuleMember -Function New-HtmlTable, New-HtmlStatCard, New-HtmlAlert, Format-DateColumn, New-HtmlStatsGrid, New-M365AssessmentReport
